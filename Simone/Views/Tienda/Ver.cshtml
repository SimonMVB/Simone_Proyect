@model Simone.Controllers.TiendaViewModel
@using System.Globalization

@{
    ViewData["Title"] = Model.Vendedor.Nombre + " · Tienda";
    var culture = new CultureInfo("en-US");

    // Helpers de vista
    bool TieneFoto          = !string.IsNullOrWhiteSpace(Model.Usuario.FotoPerfil);
    bool TieneBanner        = !string.IsNullOrWhiteSpace(Model.Vendedor.BannerPath);
    string Inicial          = Model.Vendedor.Nombre.Length > 0 ? Model.Vendedor.Nombre[0].ToString().ToUpper() : "?";
    string Banner(string? path) => string.IsNullOrWhiteSpace(path) ? "" : path;
    string Img(string? path)    => string.IsNullOrWhiteSpace(path) ? Url.Content("~/images/placeholder-product.svg") : path;

    bool EsNuevo(DateTime fecha) => (DateTime.UtcNow - fecha).TotalDays <= 30;
}

<!-- ══════════════════════════════════════════════════════════════════════
     ESTILOS ESPECÍFICOS DE LA TIENDA
══════════════════════════════════════════════════════════════════════ -->
<style>
    /* ── Variables de la página ── */
    :root {
        --store-accent: #e91e8c;
        --store-accent-light: #fce4f3;
        --store-bg: #fafafa;
        --store-card-shadow: 0 2px 12px rgba(0,0,0,.08);
        --store-radius: 14px;
    }

    /* ── Banner hero ── */
    .store-hero {
        position: relative;
        width: 100%;
        height: 280px;
        overflow: hidden;
        background: #f0f0f0;
    }
    .store-hero img.banner {
        width: 100%; height: 100%;
        object-fit: cover;
        object-position: center;
    }
    .store-hero-overlay {
        position: absolute; inset: 0;
        background: linear-gradient(to bottom, rgba(0,0,0,.05) 0%, rgba(0,0,0,.45) 100%);
    }

    /* ── Info card sobre el banner ── */
    .store-profile-card {
        position: relative;
        max-width: 960px;
        margin: -72px auto 0;
        background: #fff;
        border-radius: var(--store-radius);
        box-shadow: var(--store-card-shadow);
        padding: 28px 32px 24px;
        display: flex;
        gap: 24px;
        align-items: flex-start;
        z-index: 10;
    }
    @@media (max-width: 600px) {
        .store-profile-card { flex-direction: column; align-items: center; text-align: center; margin: -48px 12px 0; padding: 20px 18px 18px; }
    }

    .store-avatar {
        flex-shrink: 0;
        width: 100px; height: 100px;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid #fff;
        box-shadow: 0 2px 12px rgba(0,0,0,.15);
        background: #eee;
    }
    .store-avatar-initials {
        flex-shrink: 0;
        width: 100px; height: 100px;
        border-radius: 50%;
        border: 4px solid #fff;
        box-shadow: 0 2px 12px rgba(0,0,0,.15);
        background: linear-gradient(135deg, #e91e8c, #c1166f);
        display: flex; align-items: center; justify-content: center;
        font-size: 2.2rem; font-weight: 700; color: #fff;
        user-select: none;
    }
    /* Banner vacío (degradado de fondo cuando no hay imagen) */
    .store-hero.no-banner {
        background: linear-gradient(135deg, #e91e8c 0%, #880e4f 100%);
    }

    .store-name {
        font-size: 1.5rem; font-weight: 700;
        color: #1a1a1a; margin: 0 0 4px;
        display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
    }
    .badge-verified {
        display: inline-flex; align-items: center; gap: 4px;
        background: var(--store-accent); color: #fff;
        font-size: .68rem; font-weight: 600; letter-spacing: .5px;
        padding: 2px 8px; border-radius: 20px;
    }
    .store-bio {
        color: #555; font-size: .93rem; margin: 6px 0 10px;
        max-width: 520px; line-height: 1.5;
    }
    .store-stats {
        display: flex; gap: 18px; flex-wrap: wrap;
        font-size: .82rem; color: #777;
    }
    .store-stats span { display: flex; align-items: center; gap: 5px; }
    .store-stats i { color: var(--store-accent); }

    /* ── Acciones (WhatsApp, redes) ── */
    .store-actions {
        margin-left: auto; display: flex; flex-direction: column; gap: 8px; align-items: flex-end; flex-shrink: 0;
    }
    @@media (max-width: 600px) { .store-actions { align-items: center; margin-left: 0; } }
    .btn-wa {
        display: inline-flex; align-items: center; gap: 7px;
        background: #25d366; color: #fff; border: none;
        padding: 9px 18px; border-radius: 8px; font-size: .9rem; font-weight: 600;
        text-decoration: none; cursor: pointer; transition: background .15s;
    }
    .btn-wa:hover { background: #1ebe5b; color: #fff; }
    .social-links { display: flex; gap: 8px; }
    .social-links a {
        display: inline-flex; align-items: center; justify-content: center;
        width: 34px; height: 34px; border-radius: 8px;
        background: #f3f3f3; color: #555; font-size: 1rem;
        text-decoration: none; transition: background .15s, color .15s;
    }
    .social-links a:hover { background: var(--store-accent); color: #fff; }

    /* ── Barra filtros ── */
    .store-toolbar {
        max-width: 960px; margin: 22px auto 0;
        display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
    }
    .cat-filter {
        display: flex; gap: 8px; flex-wrap: wrap; flex: 1;
    }
    .cat-chip {
        display: inline-block; padding: 6px 14px; border-radius: 20px;
        font-size: .82rem; font-weight: 500; border: 1.5px solid #e0e0e0;
        background: #fff; color: #555; text-decoration: none; cursor: pointer;
        transition: all .15s;
    }
    .cat-chip:hover, .cat-chip.active {
        background: var(--store-accent); border-color: var(--store-accent); color: #fff;
    }
    .sort-select {
        padding: 6px 12px; border-radius: 8px; border: 1.5px solid #e0e0e0;
        font-size: .85rem; background: #fff; cursor: pointer; color: #444;
    }

    /* ── Grid productos ── */
    .store-grid-wrapper {
        max-width: 960px; margin: 20px auto 60px;
    }
    .store-product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 18px;
    }
    @@media (max-width: 480px) {
        .store-product-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    }

    /* ── Tarjeta producto ── */
    .sp-card {
        background: #fff; border-radius: var(--store-radius);
        box-shadow: var(--store-card-shadow); overflow: hidden;
        transition: transform .18s, box-shadow .18s; text-decoration: none;
        display: flex; flex-direction: column;
    }
    .sp-card:hover { transform: translateY(-4px); box-shadow: 0 6px 20px rgba(0,0,0,.13); }

    .sp-img-wrap {
        position: relative; width: 100%; padding-top: 120%;
        overflow: hidden; background: #f5f5f5;
    }
    .sp-img-wrap img {
        position: absolute; inset: 0; width: 100%; height: 100%;
        object-fit: cover; transition: transform .3s;
    }
    .sp-card:hover .sp-img-wrap img { transform: scale(1.05); }

    .sp-badge {
        position: absolute; top: 8px; left: 8px;
        background: var(--store-accent); color: #fff;
        font-size: .65rem; font-weight: 700; letter-spacing: .4px;
        padding: 2px 8px; border-radius: 12px;
    }
    .sp-badge.out { background: #bbb; }

    .sp-body { padding: 12px; flex: 1; display: flex; flex-direction: column; gap: 4px; }
    .sp-name {
        font-size: .88rem; font-weight: 600; color: #222;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
    }
    .sp-brand { font-size: .75rem; color: #999; }
    .sp-price { font-size: 1rem; font-weight: 700; color: var(--store-accent); margin-top: auto; padding-top: 6px; }
    .sp-price-range { font-size: .85rem; }

    /* ── Estado vacío ── */
    .store-empty {
        grid-column: 1 / -1; text-align: center; padding: 60px 20px;
        color: #aaa; font-size: .95rem;
    }
    .store-empty i { font-size: 3rem; display: block; margin-bottom: 12px; }

    /* Estrellitas */
    .stars { color: #f5a623; font-size: .8rem; letter-spacing: -1px; }
</style>

<!-- ══════════════════════════════════════════════════════════════════════
     BANNER HERO
══════════════════════════════════════════════════════════════════════ -->
<div class="store-hero @(!TieneBanner ? "no-banner" : "")">
    @if (TieneBanner)
    {
        <img class="banner"
             src="@Model.Vendedor.BannerPath"
             alt="Banner de @Model.Vendedor.Nombre">
    }
    <div class="store-hero-overlay"></div>
</div>

<!-- ══════════════════════════════════════════════════════════════════════
     TARJETA DE PERFIL
══════════════════════════════════════════════════════════════════════ -->
<div class="store-profile-card">
    <!-- Avatar -->
    @if (TieneFoto)
    {
        <img class="store-avatar"
             src="@Model.Usuario.FotoPerfil"
             alt="Foto de @Model.Vendedor.Nombre">
    }
    else
    {
        <div class="store-avatar-initials" aria-hidden="true">@Inicial</div>
    }

    <!-- Info -->
    <div style="flex:1; min-width:0;">
        <h1 class="store-name">
            @Model.Vendedor.Nombre
            @if (Model.Vendedor.Verificado)
            {
                <span class="badge-verified">
                    <i class="fas fa-check-circle" aria-hidden="true"></i> Verificado
                </span>
            }
        </h1>

        @if (!string.IsNullOrWhiteSpace(Model.Vendedor.Bio))
        {
            <p class="store-bio">@Model.Vendedor.Bio</p>
        }

        <div class="store-stats">
            <span><i class="fas fa-box-open" aria-hidden="true"></i> @Model.TotalProductos productos</span>
            <span><i class="fas fa-shopping-bag" aria-hidden="true"></i> @Model.TotalVentas ventas</span>
            @if (Model.TotalResenas > 0)
            {
                <span>
                    <span class="stars">
                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= Math.Floor(Model.RatingPromedio))
                            { <text>★</text> }
                            else if (i - Model.RatingPromedio < 1 && i - Model.RatingPromedio > 0)
                            { <text>½</text> }
                            else
                            { <text>☆</text> }
                        }
                    </span>
                    @Model.RatingPromedio (@Model.TotalResenas reseñas)
                </span>
            }
            <span>
                <i class="fas fa-calendar-alt" aria-hidden="true"></i>
                Miembro desde @Model.Usuario.FechaRegistro.ToString("MMMM yyyy", new CultureInfo("es-ES"))
            </span>
        </div>
    </div>

    <!-- Acciones -->
    <div class="store-actions">
        @if (!string.IsNullOrWhiteSpace(Model.WhatsApp))
        {
            var waNum = Model.WhatsApp.Replace("+", "").Replace(" ", "").Replace("-", "");
            var waMsg = Uri.EscapeDataString($"Hola, me interesa un producto de tu tienda {Model.Vendedor.Nombre}");
            <a class="btn-wa"
               href="https://wa.me/@waNum?text=@waMsg"
               target="_blank" rel="noopener"
               aria-label="Contactar por WhatsApp">
                <i class="fab fa-whatsapp" aria-hidden="true"></i> WhatsApp
            </a>
        }

        @{
            bool haySocial = !string.IsNullOrWhiteSpace(Model.Vendedor.InstagramUrl)
                          || !string.IsNullOrWhiteSpace(Model.Vendedor.TikTokUrl)
                          || !string.IsNullOrWhiteSpace(Model.Vendedor.FacebookUrl);
        }
        @if (haySocial)
        {
            <div class="social-links">
                @if (!string.IsNullOrWhiteSpace(Model.Vendedor.InstagramUrl))
                {
                    <a href="@Model.Vendedor.InstagramUrl" target="_blank" rel="noopener" aria-label="Instagram de @Model.Vendedor.Nombre">
                        <i class="fab fa-instagram" aria-hidden="true"></i>
                    </a>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Vendedor.TikTokUrl))
                {
                    <a href="@Model.Vendedor.TikTokUrl" target="_blank" rel="noopener" aria-label="TikTok de @Model.Vendedor.Nombre">
                        <i class="fab fa-tiktok" aria-hidden="true"></i>
                    </a>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Vendedor.FacebookUrl))
                {
                    <a href="@Model.Vendedor.FacebookUrl" target="_blank" rel="noopener" aria-label="Facebook de @Model.Vendedor.Nombre">
                        <i class="fab fa-facebook-f" aria-hidden="true"></i>
                    </a>
                }
            </div>
        }
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════════════
     BARRA DE FILTROS Y ORDENAMIENTO
══════════════════════════════════════════════════════════════════════ -->
<div class="store-toolbar">
    <div class="cat-filter">
        <!-- Chip "Todos" -->
        <a class="cat-chip @(Model.CatSeleccionada == null ? "active" : "")"
           href="/tienda/@Model.Vendedor.Slug@(Model.OrdenSeleccionado != "recientes" ? "?orden=" + Model.OrdenSeleccionado : "")">
            Todos
        </a>

        @foreach (var cat in Model.Categorias)
        {
            var isActive = Model.CatSeleccionada == cat.CategoriaID;
            var href = $"/tienda/{Model.Vendedor.Slug}?cat={cat.CategoriaID}"
                     + (Model.OrdenSeleccionado != "recientes" ? $"&orden={Model.OrdenSeleccionado}" : "");
            <a class="cat-chip @(isActive ? "active" : "")" href="@href">
                @cat.Nombre
            </a>
        }
    </div>

    <!-- Ordenar -->
    <select class="sort-select" id="sortSelect" aria-label="Ordenar por">
        <option value="recientes"   selected="@(Model.OrdenSeleccionado == "recientes"   ? "selected" : null)">Más recientes</option>
        <option value="precio_asc"  selected="@(Model.OrdenSeleccionado == "precio_asc"  ? "selected" : null)">Precio: menor a mayor</option>
        <option value="precio_desc" selected="@(Model.OrdenSeleccionado == "precio_desc" ? "selected" : null)">Precio: mayor a menor</option>
        <option value="nombre_asc"  selected="@(Model.OrdenSeleccionado == "nombre_asc"  ? "selected" : null)">Nombre A–Z</option>
        <option value="antiguos"    selected="@(Model.OrdenSeleccionado == "antiguos"    ? "selected" : null)">Más antiguos</option>
    </select>
</div>

<!-- ══════════════════════════════════════════════════════════════════════
     GRID DE PRODUCTOS
══════════════════════════════════════════════════════════════════════ -->
<div class="store-grid-wrapper">
    <div class="store-product-grid">

        @if (!Model.Productos.Any())
        {
            <div class="store-empty">
                <i class="fas fa-box-open" aria-hidden="true"></i>
                <p>No hay productos disponibles en este momento.</p>
            </div>
        }
        else
        {
            foreach (var p in Model.Productos)
            {
                var variantes   = p.Variantes?.ToList() ?? new();
                var tieneStock  = variantes.Any() ? variantes.Any(v => v.Stock > 0) : p.Stock > 0;
                var minPrecio   = variantes.Any(v => v.Stock > 0)
                                    ? variantes.Where(v => v.Stock > 0).Min(v => v.PrecioVenta ?? p.PrecioVenta)
                                    : p.PrecioVenta;
                var maxPrecio   = variantes.Any(v => v.Stock > 0)
                                    ? variantes.Where(v => v.Stock > 0).Max(v => v.PrecioVenta ?? p.PrecioVenta)
                                    : p.PrecioVenta;
                var precioRango = minPrecio == maxPrecio
                                    ? minPrecio.ToString("C0", culture)
                                    : $"{minPrecio.ToString("C0", culture)} – {maxPrecio.ToString("C0", culture)}";

                <a class="sp-card"
                   href="@Url.Action("VerProducto", "Compras", new { productoID = p.ProductoID })"
                   aria-label="Ver @p.Nombre">

                    <div class="sp-img-wrap">
                        <img src="@Img(p.ImagenPath)"
                             alt="@p.Nombre"
                             loading="lazy"
                             onerror="this.src='@Url.Content("~/images/placeholder-product.svg")'">

                        @if (!tieneStock)
                        {
                            <span class="sp-badge out">Agotado</span>
                        }
                        else if (EsNuevo(p.FechaAgregado))
                        {
                            <span class="sp-badge">Nuevo</span>
                        }
                    </div>

                    <div class="sp-body">
                        <div class="sp-name">@p.Nombre</div>
                        @if (!string.IsNullOrWhiteSpace(p.Marca))
                        {
                            <div class="sp-brand">@p.Marca</div>
                        }
                        <div class="sp-price @(variantes.Count > 1 ? "sp-price-range" : "")">
                            @precioRango
                        </div>
                    </div>
                </a>
            }
        }
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════════════
     SCRIPT: sort → navega con el ordenamiento seleccionado
══════════════════════════════════════════════════════════════════════ -->
<script>
(function () {
    const sel = document.getElementById('sortSelect');
    if (!sel) return;

    sel.addEventListener('change', function () {
        const slug = '@Model.Vendedor.Slug';
        const cat  = @(Model.CatSeleccionada.HasValue ? Model.CatSeleccionada.Value.ToString() : "null");
        const orden = this.value;

        let url = '/tienda/' + slug;
        const params = new URLSearchParams();
        if (cat)   params.set('cat',   cat);
        if (orden && orden !== 'recientes') params.set('orden', orden);

        const qs = params.toString();
        window.location.href = url + (qs ? '?' + qs : '');
    });
})();
</script>
