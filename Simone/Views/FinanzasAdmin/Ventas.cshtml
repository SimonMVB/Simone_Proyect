@model Simone.Services.FinanzasPagedResult<Simone.Services.VentaResumen>
@{
    ViewData["Title"] = "Ventas";
    var desde = ViewBag.Desde as string ?? "";
    var hasta = ViewBag.Hasta as string ?? "";
    var periodo = ViewBag.Periodo as string ?? "mes";
    var estado = ViewBag.Estado as string ?? "";
    var busqueda = ViewBag.Busqueda as string ?? "";
    var pagina = (int)(ViewBag.Pagina ?? 1);

    string BadgeEstado(string e) => e switch
    {
        "Completado" or "Entregado" => "badge-green",
        "Pendiente" => "badge-amber",
        "Cancelado" => "badge-red",
        "Verificando" => "badge-blue",
        _ => "badge-gray"
    };

    string QS(int pag)
    {
        var p = new System.Collections.Generic.Dictionary<string, string>
        {
            ["periodo"] = periodo,
            ["desde"] = desde,
            ["hasta"] = hasta,
            ["estado"] = estado,
            ["busqueda"] = busqueda,
            ["pagina"] = pag.ToString()
        };
        return "?" + string.Join("&", p.Where(x => !string.IsNullOrEmpty(x.Value))
                                       .Select(x => $"{x.Key}={Uri.EscapeDataString(x.Value)}"));
    }
}

@section Styles {
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Syne:wght@700;800&display=swap');

        :root {
            --ink: #0d0f14;
            --ink-2: #3d4150;
            --ink-3: #8b90a0;
            --paper: #f4f3f0;
            --paper-2: #eceae5;
            --paper-3: #e2dfd8;
            --line: #d8d5ce;
            --accent: #c9472b;
            --accent-lt: #fdf1ee;
            --green: #1a7a4a;
            --green-lt: #edfaf3;
            --amber: #b45309;
            --amber-lt: #fef9ec;
            --blue: #1d4ed8;
            --blue-lt: #eff6ff;
            --r: 12px;
            --r-lg: 18px;
            --sh: 0 1px 3px rgba(0,0,0,.06);
            --sh-md: 0 4px 20px rgba(0,0,0,.07);
            --ease: cubic-bezier(.4,0,.2,1);
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Space Grotesk', sans-serif;
            background: var(--paper);
            color: var(--ink);
            font-size: 14px;
        }

        .fa-wrap {
            max-width: 1400px;
            margin: 0 auto;
            padding: 2rem 1.5rem 4rem;
        }

        /* TOPBAR */
        .fa-topbar {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 1.5rem;
            flex-wrap: wrap;
            margin-bottom: 1.75rem;
            padding-bottom: 1.5rem;
            border-bottom: 2px solid var(--ink);
        }

        .fa-heading-label {
            font-size: .68rem;
            font-weight: 600;
            letter-spacing: .12em;
            text-transform: uppercase;
            color: var(--accent);
            display: block;
            margin-bottom: .25rem;
        }

        .fa-heading h1 {
            font-family: 'Syne', sans-serif;
            font-size: 2rem;
            font-weight: 800;
            letter-spacing: -.03em;
            line-height: 1;
        }

        /* NAV */
        .fa-nav {
            display: flex;
            gap: .3rem;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
        }

        .fa-nav-item {
            display: flex;
            align-items: center;
            gap: .4rem;
            padding: .5rem .9rem;
            border-radius: var(--r);
            font-size: .78rem;
            font-weight: 600;
            color: var(--ink-2);
            text-decoration: none;
            transition: all .15s;
        }

            .fa-nav-item:hover {
                background: var(--paper-2);
                color: var(--ink);
            }

            .fa-nav-item.active {
                background: var(--ink);
                color: var(--paper);
            }

        /* FILTROS */
        .filtros-bar {
            display: flex;
            align-items: center;
            gap: .65rem;
            flex-wrap: wrap;
            margin-bottom: 1.25rem;
            padding: 1rem 1.2rem;
            background: var(--paper);
            border: 1.5px solid var(--line);
            border-radius: var(--r-lg);
            box-shadow: var(--sh);
        }

            .filtros-bar input[type="text"],
            .filtros-bar input[type="date"],
            .filtros-bar select {
                padding: .5rem .8rem;
                border: 1.5px solid var(--line);
                border-radius: var(--r);
                font-family: 'Space Grotesk', sans-serif;
                font-size: .8rem;
                color: var(--ink);
                background: var(--paper);
                transition: border-color .15s;
                height: 36px;
            }

                .filtros-bar input:focus,
                .filtros-bar select:focus {
                    outline: none;
                    border-color: var(--ink);
                }

            .filtros-bar input[type="text"] {
                min-width: 200px;
            }

            .filtros-bar .sep {
                color: var(--line);
                font-size: .9rem;
            }

        .btn-filtrar {
            padding: .5rem 1.1rem;
            background: var(--ink);
            color: var(--paper);
            border: none;
            border-radius: var(--r);
            font-family: 'Space Grotesk', sans-serif;
            font-size: .8rem;
            font-weight: 600;
            cursor: pointer;
            height: 36px;
            transition: opacity .15s;
            display: flex;
            align-items: center;
            gap: .4rem;
        }

            .btn-filtrar:hover {
                opacity: .85;
            }

        .btn-limpiar {
            padding: .5rem .8rem;
            background: none;
            border: 1.5px solid var(--line);
            border-radius: var(--r);
            font-size: .78rem;
            font-weight: 600;
            color: var(--ink-3);
            cursor: pointer;
            height: 36px;
            text-decoration: none;
            display: flex;
            align-items: center;
            transition: all .15s;
        }

            .btn-limpiar:hover {
                border-color: var(--accent);
                color: var(--accent);
            }

        /* STATS RÁPIDAS */
        .ventas-stats {
            display: flex;
            gap: .75rem;
            margin-bottom: 1rem;
            flex-wrap: wrap;
        }

        .vstat {
            display: flex;
            align-items: center;
            gap: .5rem;
            padding: .5rem .9rem;
            background: var(--paper);
            border: 1.5px solid var(--line);
            border-radius: var(--r);
            font-size: .8rem;
        }

        .vstat-label {
            color: var(--ink-3);
            font-weight: 500;
        }

        .vstat-val {
            font-weight: 700;
            color: var(--ink);
            font-variant-numeric: tabular-nums;
        }

        /* TABLA */
        .tabla-wrap {
            background: var(--paper);
            border: 1.5px solid var(--line);
            border-radius: var(--r-lg);
            overflow: hidden;
            box-shadow: var(--sh);
        }

        .fa-table {
            width: 100%;
            border-collapse: collapse;
        }

            .fa-table thead {
                position: sticky;
                top: 0;
                z-index: 2;
            }

            .fa-table th {
                font-size: .67rem;
                font-weight: 700;
                letter-spacing: .07em;
                text-transform: uppercase;
                color: var(--ink-3);
                padding: .75rem 1rem;
                text-align: left;
                border-bottom: 2px solid var(--line);
                background: var(--paper-2);
                white-space: nowrap;
                cursor: pointer;
                user-select: none;
            }

                .fa-table th:hover {
                    color: var(--ink);
                }

                .fa-table th.sorted {
                    color: var(--accent);
                }

            .fa-table td {
                padding: .75rem 1rem;
                font-size: .82rem;
                color: var(--ink-2);
                border-bottom: 1px solid var(--paper-2);
                vertical-align: middle;
            }

            .fa-table tr:last-child td {
                border-bottom: none;
            }

            .fa-table tr:hover td {
                background: var(--paper-2);
                cursor: pointer;
            }

            .fa-table tr.is-selected td {
                background: #fdf1ee;
            }

        .td-id {
            font-weight: 700;
            color: var(--ink-3);
            font-variant-numeric: tabular-nums;
            font-size: .75rem;
        }

        .td-client {
            font-weight: 600;
            color: var(--ink);
        }

        .td-sub {
            font-size: .72rem;
            color: var(--ink-3);
            display: block;
            margin-top: 1px;
        }

        .td-num {
            font-weight: 700;
            font-variant-numeric: tabular-nums;
            color: var(--ink);
        }

        .td-date {
            font-variant-numeric: tabular-nums;
            white-space: nowrap;
        }

        /* BADGE */
        .badge {
            display: inline-flex;
            align-items: center;
            padding: .2rem .6rem;
            border-radius: 50px;
            font-size: .68rem;
            font-weight: 700;
            letter-spacing: .03em;
            white-space: nowrap;
        }

        .badge-green {
            background: var(--green-lt);
            color: var(--green);
        }

        .badge-red {
            background: var(--accent-lt);
            color: var(--accent);
        }

        .badge-amber {
            background: var(--amber-lt);
            color: var(--amber);
        }

        .badge-blue {
            background: var(--blue-lt);
            color: var(--blue);
        }

        .badge-gray {
            background: var(--paper-3);
            color: var(--ink-3);
        }

        /* CHIP VENDEDORES */
        .vendedor-chip {
            display: inline-flex;
            align-items: center;
            padding: .15rem .45rem;
            background: var(--paper-3);
            border-radius: 4px;
            font-size: .68rem;
            font-weight: 500;
            color: var(--ink-2);
            margin: 1px;
        }

        /* ACCIONES */
        .td-actions {
            display: flex;
            gap: .35rem;
            align-items: center;
        }

        .btn-ver {
            padding: .3rem .65rem;
            border: 1.5px solid var(--line);
            border-radius: 6px;
            font-size: .72rem;
            font-weight: 600;
            color: var(--ink-2);
            background: none;
            cursor: pointer;
            text-decoration: none;
            transition: all .15s;
            white-space: nowrap;
        }

            .btn-ver:hover {
                border-color: var(--ink);
                color: var(--ink);
                background: var(--paper-2);
            }

        .btn-estado {
            padding: .3rem .65rem;
            border: 1.5px solid var(--line);
            border-radius: 6px;
            font-size: .72rem;
            font-weight: 600;
            color: var(--ink-3);
            background: none;
            cursor: pointer;
            transition: all .15s;
        }

            .btn-estado:hover {
                border-color: var(--green);
                color: var(--green);
                background: var(--green-lt);
            }

        /* PAGINACIÓN */
        .paginacion {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: .9rem 1.2rem;
            border-top: 1px solid var(--line);
            flex-wrap: wrap;
            gap: .5rem;
        }

        .pag-info {
            font-size: .78rem;
            color: var(--ink-3);
        }

            .pag-info strong {
                color: var(--ink);
            }

        .pag-btns {
            display: flex;
            gap: .3rem;
        }

        .pag-btn {
            padding: .35rem .7rem;
            border: 1.5px solid var(--line);
            border-radius: var(--r);
            font-size: .78rem;
            font-weight: 600;
            color: var(--ink-2);
            background: var(--paper);
            cursor: pointer;
            text-decoration: none;
            transition: all .15s;
            display: flex;
            align-items: center;
        }

            .pag-btn:hover:not(.disabled) {
                border-color: var(--ink);
                color: var(--ink);
            }

            .pag-btn.active {
                background: var(--ink);
                color: var(--paper);
                border-color: var(--ink);
            }

            .pag-btn.disabled {
                opacity: .35;
                pointer-events: none;
            }

        /* EMPTY */
        .table-empty {
            text-align: center;
            padding: 4rem 2rem;
            color: var(--ink-3);
        }

        .table-empty-icon {
            font-size: 2.5rem;
            margin-bottom: 1rem;
        }

        .table-empty p {
            font-size: .85rem;
        }

        /* MODAL DETALLE */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.45);
            z-index: 9000;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 1rem;
            backdrop-filter: blur(4px);
        }

            .modal-overlay.open {
                display: flex;
                animation: mIn .2s var(--ease);
            }

        @@keyframes mIn {
            from {
                opacity: 0
            }

            to {
                opacity: 1
            }
        }

        .modal-box {
            background: var(--paper);
            border: 1.5px solid var(--line);
            border-radius: var(--r-lg);
            width: 100%;
            max-width: 560px;
            max-height: 90vh;
            overflow-y: auto;
            box-shadow: 0 20px 60px rgba(0,0,0,.2);
            animation: mSlide .25s var(--ease);
        }

        @@keyframes mSlide {
            from {
                transform: translateY(20px)
            }

            to {
                transform: translateY(0)
            }
        }

        .modal-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1.2rem 1.4rem;
            border-bottom: 1px solid var(--line);
            position: sticky;
            top: 0;
            background: var(--paper);
            z-index: 1;
        }

        .modal-title {
            font-family: 'Syne', sans-serif;
            font-size: 1.15rem;
            font-weight: 700;
        }

        .modal-close {
            width: 30px;
            height: 30px;
            border: 1.5px solid var(--line);
            border-radius: 50%;
            background: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .9rem;
            transition: all .15s;
        }

            .modal-close:hover {
                background: var(--accent);
                color: #fff;
                border-color: var(--accent);
            }

        .modal-body {
            padding: 1.2rem 1.4rem;
        }

        .modal-row {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            padding: .55rem 0;
            border-bottom: 1px solid var(--paper-2);
            font-size: .83rem;
        }

            .modal-row:last-child {
                border-bottom: none;
            }

        .modal-row-label {
            color: var(--ink-3);
            font-weight: 500;
        }

        .modal-row-val {
            font-weight: 600;
            color: var(--ink);
            text-align: right;
        }

        .modal-section-title {
            font-size: .68rem;
            font-weight: 700;
            letter-spacing: .09em;
            text-transform: uppercase;
            color: var(--ink-3);
            margin: 1rem 0 .5rem;
        }

        @@media(max-width:768px) {
            .filtros-bar {
                gap: .5rem;
            }

                .filtros-bar input[type="text"] {
                    min-width: 140px;
                }

            .fa-table td, .fa-table th {
                padding: .6rem .65rem;
            }
        }
    </style>
}

<div class="fa-wrap">

    <!-- TOPBAR -->
    <div class="fa-topbar">
        <div class="fa-heading">
            <span class="fa-heading-label">Centro Financiero</span>
            <h1>Ventas</h1>
        </div>
        <a href="/FinanzasAdmin/ExportarVentas?periodo=@periodo&estado=@estado"
           style="display:flex;align-items:center;gap:.4rem;padding:.55rem 1.1rem;background:var(--ink);color:var(--paper);border-radius:var(--r);font-size:.8rem;font-weight:600;text-decoration:none;transition:opacity .15s"
           onmouseover="this.style.opacity='.8'" onmouseout="this.style.opacity='1'">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" /></svg>
            Exportar CSV
        </a>
    </div>

    <!-- NAV -->
    <nav class="fa-nav">
        <a href="/FinanzasAdmin" class="fa-nav-item">Dashboard</a>
        <a href="/FinanzasAdmin/Ingresos" class="fa-nav-item">Ingresos</a>
        <a href="/FinanzasAdmin/Ventas" class="fa-nav-item active">Ventas</a>
        <a href="/FinanzasAdmin/Vendedores" class="fa-nav-item">Vendedores</a>
        <a href="/FinanzasAdmin/Productos" class="fa-nav-item">Productos</a>
        <a href="/FinanzasAdmin/Clientes" class="fa-nav-item">Clientes</a>
    </nav>

    <!-- FILTROS -->
    <form method="get" action="/FinanzasAdmin/Ventas">
        <div class="filtros-bar">
            <input type="text" name="busqueda" value="@busqueda"
                   placeholder="Buscar cliente, email, #ID..." />
            <span class="sep">|</span>
            <label style="font-size:.75rem;font-weight:600;color:var(--ink-3)">Desde</label>
            <input type="date" name="desde" value="@desde" />
            <label style="font-size:.75rem;font-weight:600;color:var(--ink-3)">Hasta</label>
            <input type="date" name="hasta" value="@hasta" />
            <span class="sep">|</span>
            <select name="estado">
                <option value="">Todos los estados</option>
                @foreach (var e in new[] { "Pendiente", "Verificando", "Completado", "Entregado", "Cancelado" })
                {
                    if (estado == e)
                    {
                        <option value="@e" selected="selected">@e</option>
                    }
                    else
                    {
                        <option value="@e">@e</option>
                    }
                }
            </select>
            <button type="submit" class="btn-filtrar">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                Filtrar
            </button>
            @if (!string.IsNullOrEmpty(busqueda) || !string.IsNullOrEmpty(estado) || !string.IsNullOrEmpty(desde))
            {
                <a href="/FinanzasAdmin/Ventas" class="btn-limpiar">Limpiar</a>
            }
        </div>
    </form>

    <!-- STATS RÁPIDAS -->
    <div class="ventas-stats">
        <div class="vstat">
            <span class="vstat-label">Total encontradas</span>
            <span class="vstat-val">@Model.Total</span>
        </div>
        <div class="vstat">
            <span class="vstat-label">Esta página</span>
            <span class="vstat-val">@Model.Items.Count</span>
        </div>
        <div class="vstat">
            <span class="vstat-label">Monto página</span>
            <span class="vstat-val">$@Model.Items.Sum(x => x.Total).ToString("N2")</span>
        </div>
        @if (!string.IsNullOrEmpty(estado))
        {
            <div class="vstat">
                <span class="vstat-label">Filtro activo</span>
                <span class="vstat-val"><span class="badge @BadgeEstado(estado)">@estado</span></span>
            </div>
        }
        <!-- Período rápido -->
        @foreach (var p in new[] { ("hoy", "Hoy"), ("semana", "7 días"), ("mes", "Mes"), ("anio", "Año") })
        {
            <a href="/FinanzasAdmin/Ventas?periodo=@p.Item1&estado=@estado"
               style="display:flex;align-items:center;padding:.4rem .75rem;border:1.5px solid @(periodo == p.Item1 ? "var(--ink)" : "var(--line)");border-radius:var(--r);font-size:.75rem;font-weight:600;color:@(periodo == p.Item1 ? "var(--ink)" : "var(--ink-3)");text-decoration:none;background:@(periodo == p.Item1 ? "var(--paper-2)" : "transparent");transition:all .15s">
                @p.Item2
            </a>
        }
    </div>

    <!-- TABLA -->
    <div class="tabla-wrap">
        @if (!Model.Items.Any())
        {
            <div class="table-empty">
                <div class="table-empty-icon">📋</div>
                <p>No hay ventas que coincidan con los filtros seleccionados.</p>
            </div>
        }
        else
        {
            <div style="overflow-x:auto">
                <table class="fa-table" id="tabla-ventas">
                    <thead>
                        <tr>
                            <th>#ID</th>
                            <th>Cliente</th>
                            <th>Fecha</th>
                            <th>Estado</th>
                            <th>Método</th>
                            <th>Items</th>
                            <th>Total</th>
                            <th>Vendedores</th>
                            <th style="width:120px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var v in Model.Items)
                        {
                            <tr data-venta-id="@v.VentaId"
                                data-venta-json="@System.Text.Json.JsonSerializer.Serialize(v)">
                                <td><span class="td-id">#@v.VentaId</span></td>
                                <td>
                                    <span class="td-client">@v.NombreCliente</span>
                                    <span class="td-sub">@v.EmailCliente</span>
                                </td>
                                <td class="td-date">
                                    @v.FechaVenta.ToString("dd/MM/yyyy")
                                    <span class="td-sub">@v.FechaVenta.ToString("HH:mm")</span>
                                </td>
                                <td>
                                    <span class="badge @BadgeEstado(v.Estado)">@v.Estado</span>
                                    @if (!string.IsNullOrEmpty(v.ComprobanteUrl))
                                    {
                                        <span title="Tiene comprobante" style="margin-left:.3rem;font-size:.75rem">📎</span>
                                    }
                                </td>
                                <td>@v.MetodoPago</td>
                                <td style="text-align:center">
                                    <span class="badge badge-gray">@v.CantidadItems</span>
                                </td>
                                <td><span class="td-num">$@v.Total.ToString("N2")</span></td>
                                <td>
                                    @foreach (var vend in v.Vendedores.Take(2))
                                    {
                                        <span class="vendedor-chip">@vend</span>
                                    }
                                    @if (v.Vendedores.Count > 2)
                                    {
                                        <span class="vendedor-chip">+@(v.Vendedores.Count - 2)</span>
                                    }
                                </td>
                                <td>
                                    <div class="td-actions">
                                        <a href="/FinanzasAdmin/DetalleVenta/@v.VentaId"
                                           class="btn-ver">Ver</a>
                                        <button class="btn-estado"
                                                onclick="abrirModal(@v.VentaId)"
                                                title="Ver resumen rápido">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- PAGINACIÓN -->
            <div class="paginacion">
                <span class="pag-info">
                    Mostrando <strong>@((pagina - 1) * Model.PorPagina + 1)–@Math.Min(pagina * Model.PorPagina, Model.Total)</strong>
                    de <strong>@Model.Total</strong> ventas
                </span>
                <div class="pag-btns">
                    <a href="@QS(1)" class="pag-btn @(pagina <= 1 ? "disabled" : "")">«</a>
                    <a href="@QS(pagina - 1)" class="pag-btn @(pagina <= 1 ? "disabled" : "")">‹</a>
                    @{
                        int ini = Math.Max(1, pagina - 2);
                        int fin = Math.Min(Model.TotalPaginas, ini + 4);
                    }
                    @for (int p2 = ini; p2 <= fin; p2++)
                    {
                        <a href="@QS(p2)" class="pag-btn @(p2 == pagina ? "active" : "")">@p2</a>
                    }
                    <a href="@QS(pagina + 1)" class="pag-btn @(pagina >= Model.TotalPaginas ? "disabled" : "")">›</a>
                    <a href="@QS(Model.TotalPaginas)" class="pag-btn @(pagina >= Model.TotalPaginas ? "disabled" : "")">»</a>
                </div>
            </div>
        }
    </div>

</div>

<!-- MODAL RESUMEN RÁPIDO -->
<div class="modal-overlay" id="modal-venta">
    <div class="modal-box">
        <div class="modal-head">
            <span class="modal-title" id="modal-title">Venta #—</span>
            <button class="modal-close" onclick="cerrarModal()">✕</button>
        </div>
        <div class="modal-body" id="modal-body">
            <!-- Se llena por JS -->
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            // ── Datos de todas las ventas en la página (para modal rápido)
            const ventas = {};
            document.querySelectorAll('[data-venta-id]').forEach(tr => {
                try {
                    ventas[tr.dataset.ventaId] = JSON.parse(tr.dataset.ventaJson);
                } catch {}
            });

            // ── Abrir modal con resumen
            window.abrirModal = function(id) {
                const v = ventas[id];
                if (!v) return;

                document.getElementById('modal-title').textContent = `Venta #${v.ventaId ?? v.VentaId}`;

                const badgeClass = {
                    'Completado':'badge-green','Entregado':'badge-green',
                    'Pendiente':'badge-amber','Cancelado':'badge-red',
                    'Verificando':'badge-blue'
                };

                const est   = v.estado ?? v.Estado ?? '';
                const cls   = badgeClass[est] ?? 'badge-gray';
                const fecha = new Date((v.fechaVenta ?? v.FechaVenta)).toLocaleString('es-EC');
                const total = parseFloat(v.total ?? v.Total ?? 0).toFixed(2);
                const vendedores = (v.vendedores ?? v.Vendedores ?? []).join(', ') || '—';
                const comprobante = v.comprobanteUrl ?? v.ComprobanteUrl;

                document.getElementById('modal-body').innerHTML = `
                    <p class="modal-section-title">Información general</p>
                    <div class="modal-row"><span class="modal-row-label">Estado</span>
                        <span class="modal-row-val"><span class="badge ${cls}">${est}</span></span></div>
                    <div class="modal-row"><span class="modal-row-label">Fecha</span>
                        <span class="modal-row-val">${fecha}</span></div>
                    <div class="modal-row"><span class="modal-row-label">Método de pago</span>
                        <span class="modal-row-val">${v.metodoPago ?? v.MetodoPago ?? '—'}</span></div>
                    <div class="modal-row"><span class="modal-row-label">Total</span>
                        <span class="modal-row-val" style="font-size:1.1rem;color:var(--ink)">$${total}</span></div>
                    <div class="modal-row"><span class="modal-row-label">Items</span>
                        <span class="modal-row-val">${v.cantidadItems ?? v.CantidadItems ?? '—'}</span></div>

                    <p class="modal-section-title">Cliente</p>
                    <div class="modal-row"><span class="modal-row-label">Nombre</span>
                        <span class="modal-row-val">${v.nombreCliente ?? v.NombreCliente ?? '—'}</span></div>
                    <div class="modal-row"><span class="modal-row-label">Email</span>
                        <span class="modal-row-val">${v.emailCliente ?? v.EmailCliente ?? '—'}</span></div>

                    <p class="modal-section-title">Vendedores</p>
                    <div class="modal-row"><span class="modal-row-label">Participantes</span>
                        <span class="modal-row-val">${vendedores}</span></div>

                    ${comprobante ? `
                    <p class="modal-section-title">Comprobante</p>
                    <div class="modal-row"><span class="modal-row-label">Archivo</span>
                        <span class="modal-row-val"><a href="${comprobante}" target="_blank" style="color:var(--accent);font-weight:600">Ver comprobante →</a></span></div>
                    ` : ''}

                    <div style="margin-top:1.2rem;display:flex;gap:.5rem">
                        <a href="/FinanzasAdmin/DetalleVenta/${v.ventaId ?? v.VentaId}"
                           style="flex:1;padding:.65rem;background:var(--ink);color:var(--paper);border-radius:var(--r);font-size:.82rem;font-weight:600;text-align:center;text-decoration:none;transition:opacity .15s"
                           onmouseover="this.style.opacity='.8'" onmouseout="this.style.opacity='1'">
                            Ver detalle completo →
                        </a>
                        <button onclick="cerrarModal()"
                            style="padding:.65rem 1rem;border:1.5px solid var(--line);border-radius:var(--r);font-size:.82rem;font-weight:600;background:none;cursor:pointer">
                            Cerrar
                        </button>
                    </div>
                `;

                document.getElementById('modal-venta').classList.add('open');
                document.body.style.overflow = 'hidden';
            };

            window.cerrarModal = function() {
                document.getElementById('modal-venta').classList.remove('open');
                document.body.style.overflow = '';
            };

            // Cerrar con Escape
            document.addEventListener('keydown', e => {
                if (e.key === 'Escape') cerrarModal();
            });

            // Cerrar al hacer click fuera
            document.getElementById('modal-venta').addEventListener('click', e => {
                if (e.target === e.currentTarget) cerrarModal();
            });

            // Ordenamiento client-side por columna
            const tabla = document.getElementById('tabla-ventas');
            if (!tabla) return;
            let sortDir = {};

            tabla.querySelectorAll('thead th').forEach((th, col) => {
                th.addEventListener('click', () => {
                    const dir = (sortDir[col] === 'asc') ? 'desc' : 'asc';
                    sortDir = { [col]: dir };

                    tabla.querySelectorAll('thead th').forEach(t => t.classList.remove('sorted'));
                    th.classList.add('sorted');
                    th.setAttribute('title', dir === 'asc' ? '↑ Ascendente' : '↓ Descendente');

                    const rows = [...tabla.querySelectorAll('tbody tr')];
                    rows.sort((a, b) => {
                        const va = a.cells[col]?.textContent?.trim() ?? '';
                        const vb = b.cells[col]?.textContent?.trim() ?? '';
                        const na = parseFloat(va.replace(/[$,]/g, ''));
                        const nb = parseFloat(vb.replace(/[$,]/g, ''));
                        const cmp = !isNaN(na) && !isNaN(nb)
                            ? na - nb
                            : va.localeCompare(vb, 'es');
                        return dir === 'asc' ? cmp : -cmp;
                    });

                    const tbody = tabla.querySelector('tbody');
                    rows.forEach(r => tbody.appendChild(r));
                });
            });
        })();
    </script>
}
