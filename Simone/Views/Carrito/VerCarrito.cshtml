@model IEnumerable<Simone.Models.CarritoDetalle>
@{
    ViewData["Title"] = "Carrito de Compras";
    ViewData["Description"] = "Revisa y confirma tu carrito de compras en Neo Ágora. Envío consolidado, pago seguro.";

    var totalCarrito = Model.Sum(x => x.Total);
    decimal descuento = ViewBag.Descuento ?? 0m;
    string codigoCupon = ViewBag.CodigoCupon ?? "";
    var totalConDescuento = Math.Max(0m, totalCarrito - descuento);

    // Agrupar por vendedor
    var vendedorNombres = ViewBag.VendedorNombres as Dictionary<string, string> ?? new Dictionary<string, string>();
    var itemsPorVendedor = Model
        .GroupBy(x => x.Producto?.VendedorID ?? "sin-vendedor")
        .OrderBy(g => vendedorNombres.GetValueOrDefault(g.Key, "Tienda"))
        .ToList();

    var cantidadTiendas = itemsPorVendedor.Count(g => g.Key != "sin-vendedor");
    var descuentoConsolidacion = cantidadTiendas >= 3 ? 0.15m : (cantidadTiendas >= 2 ? 0.10m : 0m);
}

@section Styles {
    <style>
        :root {
            --cart-primary: #e8b4b8;
            --cart-primary-dark: #d89da2;
            --cart-accent: #e91e63;
            --cart-success: #10b981;
            --cart-warning: #f59e0b;
            --cart-danger: #ef4444;
            --cart-dark: #2c3e50;
            --cart-light: #f8f9fa;
            --cart-border: #e5e7eb;
            --cart-radius: 12px;
            --cart-shadow: 0 4px 16px rgba(0,0,0,0.1);
            --cart-transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes zoomIn {
            from {
                transform: scale(0.9);
                opacity: 0;
            }

            to {
                transform: scale(1);
                opacity: 1;
            }
        }

        @@keyframes fadeOut {
            from {
                opacity: 1;
                transform: scale(1);
            }

            to {
                opacity: 0;
                transform: scale(0.8);
            }
        }

        @@keyframes shimmer {
            0% {
                background-position: -1000px 0;
            }

            100% {
                background-position: 1000px 0;
            }
        }

        @@keyframes pulse {
            0%, 100% {
                box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4);
            }

            50% {
                box-shadow: 0 0 0 10px rgba(16, 185, 129, 0);
            }
        }

        .cart-page {
            animation: fadeIn 0.5s ease;
            min-height: 60vh;
        }

        /* Breadcrumbs */
        .cart-breadcrumb {
            background: white;
            padding: 1rem;
            border-radius: var(--cart-radius);
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
            margin-bottom: 1.5rem;
            animation: slideDown 0.4s ease;
        }

            .cart-breadcrumb ol {
                list-style: none;
                padding: 0;
                margin: 0;
                display: flex;
                flex-wrap: wrap;
                gap: 0.5rem;
                align-items: center;
                font-size: 0.875rem;
            }

            .cart-breadcrumb li + li::before {
                content: "›";
                margin-right: 0.5rem;
                color: #6c757d;
            }

            .cart-breadcrumb a {
                color: var(--cart-accent);
                text-decoration: none;
                transition: var(--cart-transition);
            }

                .cart-breadcrumb a:hover {
                    color: var(--cart-primary-dark);
                }

        /* Progress Steps */
        .progress-steps {
            display: flex;
            justify-content: space-between;
            margin: 2rem 0;
            position: relative;
        }

            .progress-steps::before {
                content: '';
                position: absolute;
                top: 20px;
                left: 0;
                right: 0;
                height: 2px;
                background: var(--cart-border);
                z-index: 0;
            }

        .progress-step {
            flex: 1;
            text-align: center;
            position: relative;
            z-index: 1;
        }

        .progress-step-circle {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: white;
            border: 2px solid var(--cart-border);
            margin: 0 auto 0.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            transition: var(--cart-transition);
        }

        .progress-step.active .progress-step-circle {
            background: var(--cart-primary);
            border-color: var(--cart-primary);
            color: white;
            animation: zoomIn 0.4s ease;
        }

        .progress-step.completed .progress-step-circle {
            background: var(--cart-success);
            border-color: var(--cart-success);
            color: white;
        }

        /* Consolidation Banner */
        .consolidation-banner {
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            color: white;
            padding: 1rem 1.5rem;
            border-radius: var(--cart-radius);
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            animation: slideDown 0.5s ease;
        }

            .consolidation-banner i {
                font-size: 2rem;
            }

        .consolidation-banner-content h4 {
            margin: 0 0 0.25rem 0;
            font-size: 1.1rem;
        }

        .consolidation-banner-content p {
            margin: 0;
            opacity: 0.9;
            font-size: 0.9rem;
        }

        .consolidation-badge {
            background: rgba(255,255,255,0.2);
            padding: 0.25rem 0.75rem;
            border-radius: 50px;
            font-size: 0.8rem;
            margin-left: auto;
        }

        /* Vendor Group */
        .vendor-group {
            background: white;
            border-radius: var(--cart-radius);
            box-shadow: var(--cart-shadow);
            margin-bottom: 1.5rem;
            overflow: hidden;
            animation: fadeIn 0.5s ease;
        }

        .vendor-header {
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            padding: 1rem 1.5rem;
            border-bottom: 1px solid var(--cart-border);
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .vendor-icon {
            width: 40px;
            height: 40px;
            background: var(--cart-accent);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
        }

        .vendor-info h4 {
            margin: 0;
            font-size: 1rem;
            color: var(--cart-dark);
        }

        .vendor-info small {
            color: #6c757d;
        }

        .vendor-shipping {
            margin-left: auto;
            text-align: right;
        }

        .vendor-shipping-cost {
            font-weight: 700;
            color: var(--cart-accent);
        }

        /* Product Table */
        .vendor-products {
            padding: 0;
        }

        .product-row {
            display: flex;
            align-items: center;
            padding: 1rem 1.5rem;
            border-bottom: 1px solid var(--cart-border);
            transition: var(--cart-transition);
        }

            .product-row:last-child {
                border-bottom: none;
            }

            .product-row:hover {
                background: var(--cart-light);
            }

            .product-row.removing {
                animation: fadeOut 0.3s ease forwards;
            }

        .product-thumb {
            width: 70px;
            height: 70px;
            object-fit: cover;
            border-radius: 8px;
            border: 1px solid var(--cart-border);
            margin-right: 1rem;
        }

        .product-details {
            flex: 1;
            min-width: 0;
        }

        .product-name {
            font-weight: 600;
            color: var(--cart-dark);
            margin-bottom: 0.25rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .product-meta {
            font-size: 0.85rem;
            color: #6c757d;
        }

        .variant-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
            padding: 0.2rem 0.6rem;
            background: var(--cart-light);
            border: 1px solid var(--cart-border);
            border-radius: 50px;
            font-size: 0.8rem;
            margin-top: 0.25rem;
        }

        .product-quantity {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin: 0 1.5rem;
        }

            .product-quantity input {
                width: 50px !important;
                text-align: center;
                font-weight: 600;
                border: 1px solid var(--cart-border);
                border-radius: 6px;
                padding: 0.4rem;
            }

            .product-quantity button {
                width: 32px;
                height: 32px;
                border-radius: 6px;
                border: 1px solid var(--cart-border);
                background: white;
                cursor: pointer;
                transition: var(--cart-transition);
            }

                .product-quantity button:hover {
                    background: var(--cart-light);
                    transform: scale(1.05);
                }

        .product-pricing {
            text-align: right;
            min-width: 100px;
        }

        .product-price {
            font-size: 0.85rem;
            color: #6c757d;
        }

        .product-subtotal {
            font-weight: 700;
            color: var(--cart-dark);
            font-size: 1.1rem;
        }

        .product-actions {
            margin-left: 1rem;
        }

        .btn-remove {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            border: none;
            background: #fee2e2;
            color: var(--cart-danger);
            cursor: pointer;
            transition: var(--cart-transition);
        }

            .btn-remove:hover {
                background: var(--cart-danger);
                color: white;
                transform: scale(1.1);
            }

        .btn-update {
            width: 32px;
            height: 32px;
            border-radius: 6px;
            border: none;
            background: #dbeafe;
            color: #2563eb;
            cursor: pointer;
            transition: var(--cart-transition);
        }

            .btn-update:hover {
                background: #2563eb;
                color: white;
            }

        /* Summary Card */
        .summary-card {
            background: white;
            border-radius: var(--cart-radius);
            padding: 1.5rem;
            box-shadow: var(--cart-shadow);
            position: sticky;
            top: 2rem;
            animation: slideDown 0.5s ease;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 0.75rem;
            font-size: 0.95rem;
        }

            .summary-row.discount {
                color: var(--cart-success);
            }

            .summary-row.consolidation-discount {
                background: #ecfdf5;
                margin: 0.5rem -1rem;
                padding: 0.75rem 1rem;
                border-radius: 8px;
            }

            .summary-row.total {
                font-size: 1.25rem;
                font-weight: 700;
                padding-top: 0.75rem;
                border-top: 2px solid var(--cart-border);
                margin-top: 0.75rem;
            }

                .summary-row.total .value {
                    color: var(--cart-accent);
                }

        /* Shipping Info */
        .shipping-info-card {
            background: #f0f9ff;
            border: 1px solid #bae6fd;
            border-radius: 8px;
            padding: 1rem;
            margin-bottom: 1rem;
        }

            .shipping-info-card h5 {
                margin: 0 0 0.5rem 0;
                color: #0369a1;
                font-size: 0.9rem;
            }

        .hub-info {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.85rem;
            color: #0369a1;
        }

        /* Coupon Section */
        .coupon-section {
            background: white;
            border-radius: var(--cart-radius);
            padding: 1.5rem;
            box-shadow: var(--cart-shadow);
            margin-top: 1rem;
        }

        .coupon-input-group {
            display: flex;
            gap: 0.5rem;
        }

            .coupon-input-group input {
                flex: 1;
                border: 1px solid var(--cart-border);
                border-radius: 8px;
                padding: 0.75rem 1rem;
            }

        /* Shipping Section */
        .shipping-section {
            background: white;
            border-radius: var(--cart-radius);
            padding: 1.5rem;
            box-shadow: var(--cart-shadow);
            margin-top: 1rem;
        }

        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
            animation: fadeIn 0.5s ease;
        }

        .empty-state-icon {
            font-size: 5rem;
            color: var(--cart-border);
            margin-bottom: 1.5rem;
        }

        .empty-state-title {
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--cart-dark);
            margin-bottom: 0.5rem;
        }

        .empty-state-text {
            color: #6c757d;
            margin-bottom: 2rem;
        }

        /* Toast Notifications */
        .toast-container {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .toast {
            min-width: 300px;
            padding: 1rem 1.5rem;
            border-radius: var(--cart-radius);
            box-shadow: var(--cart-shadow);
            display: flex;
            align-items: center;
            gap: 1rem;
            animation: slideDown 0.3s ease;
            color: white;
        }

            .toast.success {
                background: var(--cart-success);
            }

            .toast.error {
                background: var(--cart-danger);
            }

            .toast.warning {
                background: var(--cart-warning);
            }

            .toast.removing {
                animation: fadeOut 0.3s ease forwards;
            }

        /* Modal */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.5);
            z-index: 9998;
            display: none;
            align-items: center;
            justify-content: center;
            animation: fadeIn 0.2s ease;
        }

            .modal-overlay.active {
                display: flex;
            }

        .modal-content {
            background: white;
            border-radius: var(--cart-radius);
            padding: 2rem;
            max-width: 500px;
            width: 90%;
            animation: zoomIn 0.3s ease;
            box-shadow: 0 8px 32px rgba(0,0,0,0.2);
        }

        .modal-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--cart-dark);
            margin: 0 0 1rem 0;
        }

        .modal-actions {
            display: flex;
            gap: 1rem;
            margin-top: 1.5rem;
        }

            .modal-actions button {
                flex: 1;
            }

        /* Sticky Summary Mobile */
        .sticky-summary {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: white;
            box-shadow: 0 -4px 16px rgba(0,0,0,0.1);
            padding: 1rem;
            z-index: 1000;
            transform: translateY(100%);
            transition: transform 0.3s ease;
        }

            .sticky-summary.visible {
                transform: translateY(0);
            }

        .sticky-summary-content {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
        }

        .sticky-summary-total {
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--cart-accent);
        }

        /* Loading */
        .button.loading {
            position: relative;
            pointer-events: none;
            color: transparent !important;
        }

            .button.loading::after {
                content: '';
                position: absolute;
                width: 16px;
                height: 16px;
                top: 50%;
                left: 50%;
                margin: -8px 0 0 -8px;
                border: 2px solid #fff;
                border-radius: 50%;
                border-top-color: transparent;
                animation: spin 0.6s linear infinite;
            }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .product-row {
                flex-wrap: wrap;
                gap: 0.75rem;
            }

            .product-thumb {
                width: 60px;
                height: 60px;
            }

            .product-details {
                flex: 1 1 calc(100% - 80px);
            }

            .product-quantity {
                margin: 0;
                order: 3;
            }

            .product-pricing {
                order: 4;
            }

            .product-actions {
                order: 5;
                margin-left: auto;
            }

            .summary-card {
                position: static;
            }

            .consolidation-banner {
                flex-direction: column;
                text-align: center;
            }

            .consolidation-badge {
                margin: 0.5rem 0 0 0;
            }
        }

        @@media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration: 0.01ms !important;
                transition-duration: 0.01ms !important;
            }
        }
    </style>
}

<div class="cart-page">
    <div class="ui container" style="margin-top: 2rem;">
        <!-- Breadcrumbs -->
        <nav class="cart-breadcrumb" aria-label="breadcrumb">
            <ol>
                <li><a href="@Url.Action("Index", "Home")"><i class="home icon"></i> Inicio</a></li>
                <li><a href="@Url.Action("Catalogo", "Compras")">Catálogo</a></li>
                <li aria-current="page" style="color: #2c3e50; font-weight: 600;">Carrito</li>
            </ol>
        </nav>

        <!-- Progress Steps -->
        <div class="progress-steps">
            <div class="progress-step active">
                <div class="progress-step-circle"><i class="shopping cart icon"></i></div>
                <div>Carrito</div>
            </div>
            <div class="progress-step">
                <div class="progress-step-circle">2</div>
                <div>Dirección</div>
            </div>
            <div class="progress-step">
                <div class="progress-step-circle">3</div>
                <div>Pago</div>
            </div>
            <div class="progress-step">
                <div class="progress-step-circle"><i class="check icon"></i></div>
                <div>Confirmación</div>
            </div>
        </div>

        @if (Model.Any())
        {
            <!-- Consolidation Banner -->
            @if (cantidadTiendas >= 2)
            {
                <div class="consolidation-banner">
                    <i class="box icon"></i>
                    <div class="consolidation-banner-content">
                        <h4><i class="shipping fast icon"></i> ¡Envío Consolidado Activo!</h4>
                        <p>
                            Comprando de @cantidadTiendas tiendas diferentes, tus productos se consolidan en un solo envío.
                            @if (descuentoConsolidacion > 0)
                            {
                                <strong>Ahorra @((descuentoConsolidacion * 100).ToString("0"))% en envío.</strong>
                            }
                        </p>
                    </div>
                    <span class="consolidation-badge">
                        <i class="tags icon"></i> @cantidadTiendas tiendas
                    </span>
                </div>
            }

            <!-- Header -->
            <h2 class="ui header">
                <i class="shopping cart icon"></i>
                <div class="content">
                    Carrito de Compras
                    <div class="sub header">@Model.Count() productos de @cantidadTiendas tienda(s)</div>
                </div>
            </h2>

            <div class="ui divider"></div>

            <!-- CSRF Token Form -->
            <form id="af-global" class="d-none" method="post">@Html.AntiForgeryToken()</form>

            <div id="cart-root"
                 data-descuento="@descuento"
                 data-cod="@codigoCupon"
                 data-envio="0"
                 data-tiendas="@cantidadTiendas"
                 data-descuento-consolidacion="@descuentoConsolidacion">

                <div class="ui stackable grid">
                    <!-- Left Column: Products by Vendor -->
                    <div class="eleven wide column">
                        @foreach (var grupo in itemsPorVendedor)
                        {
                            var vendedorId = grupo.Key;
                            var vendedorNombre = vendedorNombres.GetValueOrDefault(vendedorId, "Tienda");
                            var subtotalTienda = grupo.Sum(x => x.Total);
                            var itemsTienda = grupo.Count();

                            <div class="vendor-group" data-vendor="@vendedorId">
                                <div class="vendor-header">
                                    <div class="vendor-icon">
                                        <i class="store icon"></i>
                                    </div>
                                    <div class="vendor-info">
                                        <h4>@vendedorNombre</h4>
                                        <small>@itemsTienda producto(s) · Subtotal: $@subtotalTienda.ToString("F2")</small>
                                    </div>
                                    <div class="vendor-shipping">
                                        <small class="text-muted">Envío</small>
                                        <div class="vendor-shipping-cost" data-vendor-shipping="@vendedorId">--</div>
                                    </div>
                                </div>

                                <div class="vendor-products">
                                    @foreach (var item in grupo)
                                    {
                                        <div class="product-row"
                                             data-row
                                             data-id="@item.CarritoDetalleID"
                                             data-product-id="@item.ProductoID"
                                             data-variant-id="@(item.ProductoVarianteID?.ToString() ?? "")"
                                             data-vendor="@vendedorId">

                                            <img src="@(string.IsNullOrWhiteSpace(item.Producto?.ImagenPath) ? Url.Content("~/images/Productos/default.jpg") : item.Producto.ImagenPath)"
                                                 alt="@item.Producto?.Nombre"
                                                 class="product-thumb"
                                                 loading="lazy"
                                                 onerror="this.src='@Url.Content("~/images/Productos/default.jpg")';" />

                                            <div class="product-details">
                                                <div class="product-name">@item.Producto?.Nombre</div>
                                                <div class="product-meta">SKU: @item.ProductoID</div>
                                                @if (item.Variante != null)
                                                {
                                                    var variantText = string.Join(" / ", new[] {
                                                                        (item.Variante.Color ?? "").Trim(),
                                                                        (item.Variante.Talla ?? "").Trim()
                                                                        }.Where(s => !string.IsNullOrWhiteSpace(s)));

                                                    if (!string.IsNullOrEmpty(variantText))
                                                    {
                                                        <div class="variant-badge">
                                                            <i class="tag icon"></i> @variantText
                                                        </div>
                                                    }
                                                }
                                            </div>

                                            <div class="product-quantity">
                                                <button type="button" data-qty-minus aria-label="Disminuir">
                                                    <i class="minus icon"></i>
                                                </button>
                                                <input type="number" data-qty min="1" value="@item.Cantidad" aria-label="Cantidad" />
                                                <button type="button" data-qty-plus aria-label="Aumentar">
                                                    <i class="plus icon"></i>
                                                </button>
                                                <button type="button" class="btn-update" data-update title="Actualizar">
                                                    <i class="sync alternate icon"></i>
                                                </button>
                                            </div>

                                            <div class="product-pricing">
                                                <div class="product-price">$<span data-price>@item.Precio.ToString("F2")</span></div>
                                                <div class="product-subtotal">$<span data-subtotal>@item.Total.ToString("F2")</span></div>
                                            </div>

                                            <div class="product-actions">
                                                <button type="button" class="btn-remove" data-remove title="Eliminar">
                                                    <i class="trash icon"></i>
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Right Column: Summary -->
                    <div class="five wide column">
                        <div class="summary-card">
                            <h3 class="ui header">
                                <i class="calculator icon"></i> Resumen del Pedido
                            </h3>
                            <div class="ui divider"></div>

                            <div class="summary-row">
                                <span>Subtotal (@Model.Count() items):</span>
                                <strong>$<span id="ft-subtotal">@totalCarrito.ToString("F2")</span></strong>
                            </div>

                            <div id="ft-coupon-row" class="summary-row discount @(descuento > 0 ? "" : "d-none")">
                                <span>Cupón (<span id="ft-cupon-cod">@codigoCupon</span>):</span>
                                <strong>- $<span id="ft-desc">@descuento.ToString("F2")</span></strong>
                            </div>

                            <div class="summary-row">
                                <span>Envío estimado:</span>
                                <strong>$<span id="ft-envio">0.00</span></strong>
                            </div>

                            @if (cantidadTiendas >= 2)
                            {
                                <div id="ft-consolidation-row" class="summary-row consolidation-discount">
                                    <span>
                                        <i class="gift icon"></i>
                                        Dto. consolidación (@((descuentoConsolidacion * 100).ToString("0"))%):
                                    </span>
                                    <strong class="text-success">- $<span id="ft-consolidation-desc">0.00</span></strong>
                                </div>
                            }

                            <div class="summary-row total">
                                <span>Total:</span>
                                <span class="value">$<span id="ft-total">@totalConDescuento.ToString("F2")</span></span>
                            </div>

                            <!-- Shipping Info -->
                            <div class="shipping-info-card" id="shipping-info" style="display: none;">
                                <h5><i class="building icon"></i> Hub de Consolidación</h5>
                                <div class="hub-info">
                                    <i class="map marker alternate icon"></i>
                                    <span id="hub-name">--</span>
                                </div>
                            </div>

                            <form asp-controller="Carrito" asp-action="ConfirmarCompra" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="EnvioProvincia" id="h-envio-prov" />
                                <input type="hidden" name="EnvioCiudad" id="h-envio-ciudad" />
                                <input type="hidden" name="EnvioDireccion" id="h-envio-dir" />
                                <input type="hidden" name="EnvioTelefono" id="h-envio-tel" />
                                <input type="hidden" name="EnvioPrecio" id="h-envio-precio" />

                                <button class="ui green fluid huge button" type="submit">
                                    <i class="check icon"></i> Confirmar Compra
                                </button>
                            </form>

                            <div class="ui tiny grey text" style="margin-top: 0.75rem; text-align: center;">
                                <i class="shield alternate icon"></i> Pago 100% seguro
                                <br>
                                <i class="box icon"></i> Envío consolidado garantizado
                            </div>
                        </div>

                        <!-- Coupon Section -->
                        <div class="coupon-section">
                            <h4 class="ui header"><i class="tag icon"></i> Cupón de Descuento</h4>
                            <div class="coupon-input-group">
                                <input type="text" id="coupon-input" placeholder="Código de cupón"
                                       value="@(descuento > 0 ? codigoCupon : "")" />
                                <button type="button" class="ui teal button" id="btn-apply-coupon">Aplicar</button>
                            </div>
                            <div id="ft-coupon-actions" class="@(descuento > 0 ? "" : "d-none")" style="margin-top: 0.5rem;">
                                <button type="button" class="ui tiny red button" id="btn-remove-coupon">
                                    <i class="close icon"></i> Quitar
                                </button>
                            </div>
                        </div>

                        <!-- Shipping Section -->
                        <div class="shipping-section">
                            <h4 class="ui header"><i class="truck icon"></i> Calcular Envío</h4>
                            <div class="ui form">
                                <div class="field">
                                    <label>Provincia</label>
                                    <select id="ddl-provincia" class="ui dropdown">
                                        <option value="">Selecciona provincia…</option>
                                    </select>
                                </div>
                                <div class="field">
                                    <label>Ciudad</label>
                                    <select id="ddl-ciudad" class="ui dropdown">
                                        <option value="">(toda la provincia)</option>
                                    </select>
                                </div>
                                <button type="button" class="ui fluid button" id="btn-calc-envio">
                                    <i class="calculator icon"></i> Calcular Envío Consolidado
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <!-- Empty State -->
            <div class="empty-state">
                <div class="empty-state-icon"><i class="shopping basket icon"></i></div>
                <h3 class="empty-state-title">Tu carrito está vacío</h3>
                <p class="empty-state-text">Descubre miles de productos en nuestro catálogo</p>
                <a href="@Url.Action("Catalogo", "Compras")" class="ui large primary button">
                    <i class="shopping bag icon"></i> Ver Catálogo
                </a>
            </div>
        }
    </div>
</div>

<!-- Sticky Summary Mobile -->
<div class="sticky-summary" id="sticky-summary" aria-hidden="true">
    <div class="sticky-summary-content">
        <div>
            <div class="ui tiny grey text">Total a Pagar</div>
            <div class="sticky-summary-total">$<span id="sticky-total">@totalConDescuento.ToString("F2")</span></div>
        </div>
        <button class="ui green button" id="sticky-checkout-btn">
            <i class="check icon"></i> Confirmar
        </button>
    </div>
</div>

<!-- Confirmation Modal -->
<div class="modal-overlay" id="confirm-modal" role="dialog" aria-modal="true">
    <div class="modal-content">
        <h3 class="modal-title"><i class="exclamation triangle icon"></i> Confirmar Eliminación</h3>
        <p id="modal-message">¿Estás seguro de que deseas eliminar este producto?</p>
        <div class="modal-actions">
            <button class="ui button" id="modal-cancel">Cancelar</button>
            <button class="ui red button" id="modal-confirm"><i class="trash icon"></i> Eliminar</button>
        </div>
    </div>
</div>

<!-- Toast Container -->
<div class="toast-container" id="toast-container" role="status" aria-live="polite"></div>

@section Scripts {
    <script>
        (function() {
            'use strict';

            const CONFIG = {
                endpoints: {
                    update: '/Carrito/ActualizarCarrito',
                    remove: '/Carrito/EliminarDelCarrito',
                    applyCoupon: '/Carrito/AplicarCupon',
                    removeCoupon: '/Carrito/QuitarCupon',
                    cartInfo: '/Carrito/CartInfo',
                    shippingEstimate: '/api/envios/estimar'
                },
                provinces: {
                    "Azuay": ["Cuenca","Gualaceo","Paute","Sígsig","Nabón","Girón","Santa Isabel"],
                    "Bolívar": ["Guaranda","Chillanes","Echeandía"],
                    "Cañar": ["Azogues","La Troncal","El Tambo","Cañar"],
                    "Carchi": ["Tulcán","Montúfar","Mira"],
                    "Chimborazo": ["Riobamba","Guano","Alausí","Colta","Chambo"],
                    "Cotopaxi": ["Latacunga","Salcedo","Saquisilí","Pujilí"],
                    "El Oro": ["Machala","Santa Rosa","Pasaje","Huaquillas","Arenillas"],
                    "Esmeraldas": ["Esmeraldas","Atacames","Quinindé","Muisne"],
                    "Galápagos": ["Puerto Ayora","Puerto Baquerizo Moreno","Puerto Villamil"],
                    "Guayas": ["Guayaquil","Daule","Samborondón","Durán","Milagro","Playas","El Triunfo","Naranjal","Balao"],
                    "Imbabura": ["Ibarra","Otavalo","Cotacachi","Atuntaqui"],
                    "Loja": ["Loja","Catamayo","Macará","Cariamanga"],
                    "Los Ríos": ["Babahoyo","Quevedo","Vinces","Puebloviejo","Buena Fe"],
                    "Manabí": ["Portoviejo","Manta","Chone","Bahía de Caráquez","Jipijapa","El Carmen"],
                    "Morona Santiago": ["Macas","Sucúa","Gualaquiza","Taisha"],
                    "Napo": ["Tena","Archidona","El Chaco"],
                    "Orellana": ["Coca","La Joya de los Sachas","Loreto"],
                    "Pastaza": ["Puyo","Mera","Santa Clara"],
                    "Pichincha": ["Quito","Sangolquí","Cayambe","Machachi","San Antonio de Pichincha"],
                    "Santa Elena": ["La Libertad","Salinas","Santa Elena"],
                    "Santo Domingo de los Tsáchilas": ["Santo Domingo","La Concordia"],
                    "Sucumbíos": ["Lago Agrio","Shushufindi","Cuyabeno"],
                    "Tungurahua": ["Ambato","Baños","Pelileo","Tisaleo","Cevallos"],
                    "Zamora Chinchipe": ["Zamora","Yantzaza","Zumba"]
                }
            };

            const el = {
                root: document.getElementById('cart-root'),
                ftSubtotal: document.getElementById('ft-subtotal'),
                ftDesc: document.getElementById('ft-desc'),
                ftCuponCod: document.getElementById('ft-cupon-cod'),
                ftCouponRow: document.getElementById('ft-coupon-row'),
                ftCouponActions: document.getElementById('ft-coupon-actions'),
                ftEnvio: document.getElementById('ft-envio'),
                ftConsolidationDesc: document.getElementById('ft-consolidation-desc'),
                ftTotal: document.getElementById('ft-total'),
                couponInput: document.getElementById('coupon-input'),
                btnApplyCoupon: document.getElementById('btn-apply-coupon'),
                btnRemoveCoupon: document.getElementById('btn-remove-coupon'),
                ddlProvincia: document.getElementById('ddl-provincia'),
                ddlCiudad: document.getElementById('ddl-ciudad'),
                btnCalcEnvio: document.getElementById('btn-calc-envio'),
                hEnvioProv: document.getElementById('h-envio-prov'),
                hEnvioCiudad: document.getElementById('h-envio-ciudad'),
                hEnvioPrecio: document.getElementById('h-envio-precio'),
                shippingInfo: document.getElementById('shipping-info'),
                hubName: document.getElementById('hub-name'),
                stickySummary: document.getElementById('sticky-summary'),
                stickyTotal: document.getElementById('sticky-total'),
                stickyCheckoutBtn: document.getElementById('sticky-checkout-btn'),
                confirmModal: document.getElementById('confirm-modal'),
                modalCancel: document.getElementById('modal-cancel'),
                modalConfirm: document.getElementById('modal-confirm'),
                modalMessage: document.getElementById('modal-message'),
                toastContainer: document.getElementById('toast-container'),
                afGlobal: document.getElementById('af-global')
            };

            let state = { modalCallback: null };

            const fmt = (n) => (Number(n || 0)).toFixed(2);
            const parseN = (s) => { const n = Number(String(s || '').replace(/[^0-9.-]/g, '')); return isNaN(n) ? 0 : n; };
            const token = () => el.afGlobal?.querySelector('input[name="__RequestVerificationToken"]')?.value;

            function showToast(type, message) {
                const toast = document.createElement('div');
                toast.className = `toast ${type}`;
                const icon = type === 'success' ? 'check circle' : type === 'error' ? 'times circle' : 'exclamation triangle';
                toast.innerHTML = `<i class="${icon} icon"></i><div>${message}</div>`;
                el.toastContainer.appendChild(toast);
                setTimeout(() => { toast.classList.add('removing'); setTimeout(() => toast.remove(), 300); }, 3000);
            }

            function showModal(message, callback) {
                el.modalMessage.textContent = message;
                state.modalCallback = callback;
                el.confirmModal.classList.add('active');
            }

            function hideModal() {
                el.confirmModal.classList.remove('active');
                state.modalCallback = null;
            }

            function recomputeFooter() {
                const rows = Array.from(document.querySelectorAll('[data-row]'));
                const sum = rows.reduce((acc, row) => acc + parseN(row.querySelector('[data-subtotal]')?.textContent), 0);

                el.ftSubtotal.textContent = fmt(sum);

                const desc = parseN(el.root?.dataset.descuento || 0);
                const envioBase = parseN(el.ftEnvio?.textContent || 0);
                const descConsolidacion = parseN(el.root?.dataset.descuentoConsolidacion || 0);
                const envioDescuento = envioBase * descConsolidacion;
                const envioFinal = envioBase - envioDescuento;

                if (el.ftConsolidationDesc) el.ftConsolidationDesc.textContent = fmt(envioDescuento);

                const total = Math.max(0, sum - desc) + envioFinal;
                el.ftTotal.textContent = fmt(total);
                if (el.stickyTotal) el.stickyTotal.textContent = fmt(total);

                el.ftCouponRow?.classList.toggle('d-none', desc <= 0);
                el.ftCouponActions?.classList.toggle('d-none', desc <= 0);
            }

            async function refreshWidget() {
                try {
                    const response = await fetch(CONFIG.endpoints.cartInfo, { credentials: 'same-origin' });
                    if (!response.ok) return;
                    const data = await response.json();
                    const countEl = document.getElementById('cart-count');
                    const totalEl = document.getElementById('cart-total');
                    if (countEl) countEl.textContent = data.count ?? 0;
                    if (totalEl) totalEl.textContent = new Intl.NumberFormat('es-EC', { style: 'currency', currency: 'USD' }).format(data.subtotal ?? 0);
                } catch (e) { console.error('Widget refresh error:', e); }
            }

            function setLoading(button, loading) {
                if (loading) { button.classList.add('loading'); button.disabled = true; }
                else { button.classList.remove('loading'); button.disabled = false; }
            }

            // Quantity controls
            document.addEventListener('click', (e) => {
                const minus = e.target.closest('[data-qty-minus]');
                if (minus) {
                    const input = minus.closest('[data-row]')?.querySelector('[data-qty]');
                    if (input) input.value = Math.max(1, parseInt(input.value || 1) - 1);
                }
                const plus = e.target.closest('[data-qty-plus]');
                if (plus) {
                    const input = plus.closest('[data-row]')?.querySelector('[data-qty]');
                    if (input) input.value = parseInt(input.value || 1) + 1;
                }
            });

            // Update quantity
            document.addEventListener('click', async (e) => {
                const btn = e.target.closest('[data-update]');
                if (!btn) return;

                const row = btn.closest('[data-row]');
                const id = row?.dataset.id;
                const pid = row?.dataset.productId;
                const input = row?.querySelector('[data-qty]');
                const qty = Math.max(1, Number(input?.value || 1));

                if (!id) return;
                setLoading(btn, true);

                const fd = new FormData();
                fd.append('carritoDetalleId', id);
                if (pid) fd.append('productoId', pid);
                fd.append('cantidad', qty);
                const tk = token();
                if (tk) fd.append('__RequestVerificationToken', tk);

                try {
                    const response = await fetch(CONFIG.endpoints.update, {
                        method: 'POST', body: fd,
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                        credentials: 'same-origin'
                    });
                    const data = response.ok ? await response.json() : null;

                    if (data?.ok) {
                        const price = parseN(row.querySelector('[data-price]')?.textContent);
                        row.querySelector('[data-subtotal]').textContent = fmt(data.lineSubtotal ?? (qty * price));
                        recomputeFooter();
                        refreshWidget();
                        showToast('success', 'Cantidad actualizada');
                    } else {
                        showToast('error', data?.error || 'No se pudo actualizar');
                    }
                } catch (error) {
                    showToast('error', 'Error de conexión');
                } finally {
                    setLoading(btn, false);
                }
            });

            // Remove item
            document.addEventListener('click', (e) => {
                const btn = e.target.closest('[data-remove]');
                if (!btn) return;

                const row = btn.closest('[data-row]');
                const name = row?.querySelector('.product-name')?.textContent || 'este producto';

                showModal(`¿Eliminar "${name}" del carrito?`, async () => {
                    const id = row?.dataset.id;
                    const pid = row?.dataset.productId;
                    if (!id) return;

                    setLoading(btn, true);

                    const fd = new FormData();
                    fd.append('carritoDetalleId', id);
                    if (pid) fd.append('productoId', pid);
                    const tk = token();
                    if (tk) fd.append('__RequestVerificationToken', tk);

                    try {
                        const response = await fetch(CONFIG.endpoints.remove, {
                            method: 'POST', body: fd,
                            headers: { 'X-Requested-With': 'XMLHttpRequest' },
                            credentials: 'same-origin'
                        });
                        const data = response.ok ? await response.json() : null;

                        if (data?.ok) {
                            row.classList.add('removing');
                            setTimeout(() => {
                                row.remove();
                                const remaining = document.querySelectorAll('[data-row]').length;
                                if (remaining === 0) { location.reload(); return; }

                                // Check if vendor group is empty
                                document.querySelectorAll('.vendor-group').forEach(group => {
                                    if (group.querySelectorAll('[data-row]').length === 0) group.remove();
                                });

                                recomputeFooter();
                                refreshWidget();
                                showToast('success', 'Producto eliminado');
                            }, 300);
                        } else {
                            showToast('error', data?.error || 'No se pudo eliminar');
                            setLoading(btn, false);
                        }
                    } catch (error) {
                        showToast('error', 'Error de conexión');
                        setLoading(btn, false);
                    }
                });
            });

            // Modal handlers
            el.modalCancel?.addEventListener('click', hideModal);
            el.modalConfirm?.addEventListener('click', () => { if (state.modalCallback) state.modalCallback(); hideModal(); });
            el.confirmModal?.addEventListener('click', (e) => { if (e.target === el.confirmModal) hideModal(); });

            // Coupon
            el.btnApplyCoupon?.addEventListener('click', async () => {
                const code = el.couponInput?.value?.trim();
                if (!code) { showToast('warning', 'Ingresa un código'); return; }

                setLoading(el.btnApplyCoupon, true);
                const fd = new FormData();
                fd.append('codigoCupon', code);
                const tk = token();
                if (tk) fd.append('__RequestVerificationToken', tk);

                try {
                    const response = await fetch(CONFIG.endpoints.applyCoupon, {
                        method: 'POST', body: fd,
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                        credentials: 'same-origin'
                    });
                    const data = response.ok ? await response.json() : null;

                    if (data?.ok) {
                        el.root.dataset.descuento = data.descuento ?? 0;
                        el.ftDesc.textContent = fmt(data.descuento ?? 0);
                        el.ftCuponCod.textContent = data.codigo ?? '';
                        showToast('success', `Cupón "${data.codigo}" aplicado`);
                        recomputeFooter();
                    } else {
                        showToast('error', data?.error || 'Cupón inválido');
                        el.root.dataset.descuento = 0;
                        recomputeFooter();
                    }
                } catch (error) {
                    showToast('error', 'Error al aplicar cupón');
                } finally {
                    setLoading(el.btnApplyCoupon, false);
                }
            });

            el.btnRemoveCoupon?.addEventListener('click', async () => {
                setLoading(el.btnRemoveCoupon, true);
                const fd = new FormData();
                const tk = token();
                if (tk) fd.append('__RequestVerificationToken', tk);

                try {
                    await fetch(CONFIG.endpoints.removeCoupon, {
                        method: 'POST', body: fd,
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                        credentials: 'same-origin'
                    });
                    el.root.dataset.descuento = 0;
                    el.ftDesc.textContent = fmt(0);
                    el.couponInput.value = '';
                    showToast('success', 'Cupón eliminado');
                    recomputeFooter();
                } catch (error) {
                    showToast('error', 'Error al eliminar cupón');
                } finally {
                    setLoading(el.btnRemoveCoupon, false);
                }
            });

            // Shipping
            function fillProvinces() {
                el.ddlProvincia.innerHTML = '<option value="">Selecciona provincia…</option>';
                Object.keys(CONFIG.provinces).sort().forEach(p => {
                    const opt = document.createElement('option');
                    opt.value = p; opt.textContent = p;
                    el.ddlProvincia.appendChild(opt);
                });
            }

            function fillCities(province) {
                el.ddlCiudad.innerHTML = '<option value="">(toda la provincia)</option>';
                (CONFIG.provinces[province] || []).forEach(c => {
                    const opt = document.createElement('option');
                    opt.value = c; opt.textContent = c;
                    el.ddlCiudad.appendChild(opt);
                });
            }

            el.ddlProvincia?.addEventListener('change', () => {
                fillCities(el.ddlProvincia.value);
                el.ftEnvio.textContent = fmt(0);
                el.hEnvioProv.value = el.ddlProvincia.value || "";
                el.hEnvioCiudad.value = "";
                el.hEnvioPrecio.value = "0";
                if (el.shippingInfo) el.shippingInfo.style.display = 'none';
                recomputeFooter();
            });

            el.ddlCiudad?.addEventListener('change', () => {
                el.hEnvioCiudad.value = el.ddlCiudad.value || "";
            });

            el.btnCalcEnvio?.addEventListener('click', async () => {
                const prov = (el.ddlProvincia.value || '').trim();
                const city = (el.ddlCiudad.value || '').trim();

                if (!prov) { showToast('warning', 'Selecciona una provincia'); return; }

                setLoading(el.btnCalcEnvio, true);

                try {
                    const q = new URLSearchParams({ provincia: prov, ciudad: city || '' });
                    const response = await fetch(`${CONFIG.endpoints.shippingEstimate}?${q.toString()}`, { credentials: 'same-origin' });
                    const data = await response.json();

                    if (!response.ok || data?.ok === false) {
                        el.ftEnvio.textContent = fmt(0);
                        el.hEnvioPrecio.value = "0";
                        if (el.shippingInfo) el.shippingInfo.style.display = 'none';
                        showToast('error', data?.error || 'No hay tarifa para ese destino');
                        recomputeFooter();
                        return;
                    }

                    const precio = Number(data?.precio ?? data?.costoTotal ?? 0);
                    el.ftEnvio.textContent = fmt(precio);
                    el.hEnvioProv.value = prov;
                    el.hEnvioCiudad.value = city || "";
                    el.hEnvioPrecio.value = fmt(precio);

                    // Show hub info
                    if (data?.hubAsignado && el.shippingInfo) {
                        el.shippingInfo.style.display = 'block';
                        el.hubName.textContent = data.hubAsignado;
                    }

                    const descConsolidacion = parseN(el.root?.dataset.descuentoConsolidacion || 0);
                    const ahorro = precio * descConsolidacion;

                    if (ahorro > 0) {
                        showToast('success', `Envío: $${fmt(precio)} (Ahorras $${fmt(ahorro)} por consolidación)`);
                    } else {
                        showToast('success', `Envío: $${fmt(precio)}`);
                    }

                    recomputeFooter();
                } catch (error) {
                    el.ftEnvio.textContent = fmt(0);
                    el.hEnvioPrecio.value = "0";
                    if (el.shippingInfo) el.shippingInfo.style.display = 'none';
                    showToast('error', 'No se pudo calcular el envío');
                    recomputeFooter();
                } finally {
                    setLoading(el.btnCalcEnvio, false);
                }
            });

            // Sticky summary
            let lastScroll = 0;
            window.addEventListener('scroll', () => {
                const currentScroll = window.pageYOffset;
                if (window.innerWidth <= 768) {
                    if (currentScroll > 300 && currentScroll > lastScroll) {
                        el.stickySummary.classList.add('visible');
                    } else if (currentScroll < lastScroll - 50 || currentScroll < 300) {
                        el.stickySummary.classList.remove('visible');
                    }
                }
                lastScroll = currentScroll;
            });

            el.stickyCheckoutBtn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

            // Keyboard shortcuts
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape' && el.confirmModal.classList.contains('active')) hideModal();
                if (e.key === 'Enter' && e.target.matches('[data-qty]')) {
                    e.target.closest('[data-row]')?.querySelector('[data-update]')?.click();
                }
                if (e.key === 'Enter' && e.target === el.couponInput) el.btnApplyCoupon?.click();
            });

            // Init
            function init() {
                if (el.root) {
                    fillProvinces();
                    recomputeFooter();
                }
                console.log('✓ Cart initialized (consolidated shipping)');
            }

            if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
            else init();
        })();
    </script>
}
