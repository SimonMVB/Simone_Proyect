@{
    ViewData["Title"] = "Seleccionar Hub";
    var hubs = ViewBag.Hubs as List<Simone.Models.HubEnvio> ?? new List<Simone.Models.HubEnvio>();
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Header -->
            <div class="text-center mb-4">
                <a href="@Url.Action("Index", "Panel")" class="btn btn-outline-secondary btn-sm mb-3">
                    <i class="bi bi-arrow-left me-1"></i>Volver al Panel
                </a>
                <h1 class="h2">
                    <i class="bi bi-building me-2 text-primary"></i>Panel de Hubs
                </h1>
                <p class="text-muted">Selecciona un Hub para gestionar sus operaciones</p>
            </div>

            <!-- Mensajes -->
            @if (TempData["MensajeError"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show">
                    <i class="bi bi-exclamation-triangle me-2"></i>@TempData["MensajeError"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- Lista de Hubs -->
            @if (hubs.Any())
            {
                <div class="row g-4">
                    @foreach (var hub in hubs)
                    {
                        <div class="col-md-6">
                            <div class="card h-100 border-0 shadow-sm hover-shadow">
                                <div class="card-body">
                                    <div class="d-flex align-items-start">
                                        <div class="rounded-circle bg-primary bg-opacity-10 p-3 me-3">
                                            <i class="bi bi-building text-primary fs-4"></i>
                                        </div>
                                        <div class="flex-grow-1">
                                            <h5 class="card-title mb-1">@hub.Nombre</h5>
                                            <p class="text-muted small mb-2">
                                                <i class="bi bi-geo-alt me-1"></i>@hub.Ciudad, @hub.Provincia
                                            </p>
                                            <p class="text-muted small mb-0">
                                                @hub.Direccion
                                            </p>
                                        </div>
                                    </div>
                                </div>
                                <div class="card-footer bg-transparent border-0 pt-0">
                                    <a href="@Url.Action("PanelHubAdmin", new { hubId = hub.HubId })"
                                       class="btn btn-primary w-100">
                                        <i class="bi bi-box-arrow-in-right me-1"></i>Acceder
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="card">
                    <div class="card-body text-center py-5">
                        <i class="bi bi-building text-muted display-4"></i>
                        <h5 class="mt-3 text-muted">No hay Hubs activos</h5>
                        <p class="text-muted mb-3">Crea un Hub primero para poder gestionar envíos.</p>
                        <a href="@Url.Action("Hubs", "Panel")" class="btn btn-primary">
                            <i class="bi bi-plus-lg me-1"></i>Gestionar Hubs
                        </a>
                    </div>
                </div>
            }

            <!-- Info -->
            <div class="card mt-4 border-0 bg-light">
                <div class="card-body">
                    <h6 class="card-title">
                        <i class="bi bi-info-circle me-1 text-info"></i>¿Qué es un Hub?
                    </h6>
                    <p class="card-text small text-muted mb-0">
                        Los Hubs son centros de consolidación donde se reciben los paquetes de múltiples tiendas
                        y se agrupan en un solo envío para el cliente final. Desde el panel del Hub puedes:
                    </p>
                    <ul class="small text-muted mt-2 mb-0">
                        <li>Recibir paquetes de las tiendas</li>
                        <li>Ver el estado de los envíos consolidados</li>
                        <li>Despachar envíos al cliente final</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-shadow {
        transition: all 0.3s ease;
    }

        .hover-shadow:hover {
            transform: translateY(-5px);
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
        }
</style>