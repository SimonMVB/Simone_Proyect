@model Simone.Models.Vendedor
@{
    ViewData["Title"] = "Perfil de Tienda · " + Model.Nombre;
    var slugActual = Model.Slug ?? "";
    var urlPublica = !string.IsNullOrWhiteSpace(Model.Slug)
                     ? $"/tienda/{Model.Slug}"
                     : null;
}

<style>
    .perfil-tienda-wrap { max-width: 740px; margin: 0 auto; padding: 24px 16px 60px; }
    .pt-header { display: flex; align-items: center; gap: 14px; margin-bottom: 28px; }
    .pt-header h1 { font-size: 1.4rem; font-weight: 700; margin: 0; }
    .pt-section {
        background: #fff; border-radius: 12px;
        box-shadow: 0 2px 10px rgba(0,0,0,.07);
        padding: 24px 28px; margin-bottom: 20px;
    }
    .pt-section h2 { font-size: 1rem; font-weight: 700; color: #333; margin: 0 0 18px; }
    .pt-field { margin-bottom: 16px; }
    .pt-field label { display: block; font-size: .85rem; font-weight: 600; color: #444; margin-bottom: 5px; }
    .pt-field input[type=text], .pt-field textarea, .pt-field input[type=url] {
        width: 100%; border: 1.5px solid #ddd; border-radius: 8px;
        padding: 9px 12px; font-size: .9rem; outline: none; transition: border-color .15s;
    }
    .pt-field input:focus, .pt-field textarea:focus { border-color: #e91e8c; }
    .pt-field textarea { resize: vertical; min-height: 90px; }
    .pt-field small { color: #888; font-size: .77rem; margin-top: 4px; display: block; }
    .pt-field .slug-preview {
        font-size: .8rem; color: #e91e8c; margin-top: 4px;
    }
    .toggle-row {
        display: flex; align-items: center; gap: 12px;
        padding: 12px 0; border-bottom: 1px solid #f3f3f3;
    }
    .toggle-row:last-child { border-bottom: none; }
    .toggle-row label { flex: 1; font-size: .9rem; color: #333; margin: 0; }
    .toggle-row small { color: #888; font-size: .78rem; }
    .switch { position: relative; display: inline-block; width: 42px; height: 24px; }
    .switch input { opacity: 0; width: 0; height: 0; }
    .slider {
        position: absolute; inset: 0; background: #ccc; border-radius: 24px; cursor: pointer;
        transition: background .2s;
    }
    .slider:before {
        content: ""; position: absolute; width: 18px; height: 18px; border-radius: 50%;
        background: #fff; left: 3px; top: 3px; transition: transform .2s;
        box-shadow: 0 1px 4px rgba(0,0,0,.2);
    }
    input:checked + .slider { background: #e91e8c; }
    input:checked + .slider:before { transform: translateX(18px); }

    /* Banner preview */
    .banner-preview {
        width: 100%; height: 160px; border-radius: 10px;
        object-fit: cover; background: #f5f5f5;
        border: 1.5px solid #eee; margin-bottom: 10px;
    }
    .btn-save {
        background: #e91e8c; color: #fff; border: none;
        padding: 11px 28px; border-radius: 8px;
        font-size: .95rem; font-weight: 600; cursor: pointer;
        transition: background .15s;
    }
    .btn-save:hover { background: #c1166f; }
    .btn-back { color: #888; text-decoration: none; font-size: .87rem; }
    .btn-back:hover { color: #333; }
    .url-publica {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: .82rem; color: #e91e8c; text-decoration: none;
        background: #fce4f3; padding: 4px 12px; border-radius: 20px; margin-top: 4px;
    }
    .url-publica:hover { background: #f5c4e7; }
    .alert-success { background: #e8f5e9; border-left: 4px solid #4caf50; padding: 12px 16px; border-radius: 6px; color: #2e7d32; font-size: .88rem; margin-bottom: 16px; }
    .alert-error   { background: #fce4e4; border-left: 4px solid #e53935; padding: 12px 16px; border-radius: 6px; color: #c62828; font-size: .88rem; margin-bottom: 16px; }
</style>

<div class="perfil-tienda-wrap">

    <!-- Header -->
    <div class="pt-header">
        <a asp-action="Usuarios" class="btn-back"><i class="fas fa-arrow-left"></i> Usuarios</a>
        <h1><i class="fas fa-store" style="color:#e91e8c"></i> Perfil: @Model.Nombre</h1>
    </div>

    <!-- Alertas -->
    @if (TempData["MensajeExito"] != null)
    {
        <div class="alert-success"><i class="fas fa-check-circle"></i> @TempData["MensajeExito"]</div>
    }
    @if (TempData["MensajeError"] != null)
    {
        <div class="alert-error"><i class="fas fa-exclamation-circle"></i> @TempData["MensajeError"]</div>
    }

    <!-- URL pública actual -->
    @if (urlPublica != null)
    {
        <a class="url-publica" href="@urlPublica" target="_blank">
            <i class="fas fa-external-link-alt"></i> @($"{Context.Request.Scheme}://{Context.Request.Host}{urlPublica}")
        </a>
        <br><br>
    }

    <form method="post"
          asp-action="GuardarPerfilTienda"
          enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" name="VendedorId" value="@Model.VendedorId">

        <!-- ── Identidad pública ── -->
        <div class="pt-section">
            <h2><i class="fas fa-id-card" style="color:#e91e8c"></i> Identidad pública</h2>

            <div class="pt-field">
                <label for="Slug">URL amigable (slug)</label>
                <input type="text" id="Slug" name="Slug"
                       value="@slugActual"
                       placeholder="ej: modas-sofia"
                       maxlength="100"
                       pattern="[a-z0-9\-]+"
                       title="Solo minúsculas, números y guiones">
                <small>Solo minúsculas, números y guiones. Sin espacios ni caracteres especiales.</small>
                <div class="slug-preview" id="slugPreview">
                    @if (!string.IsNullOrWhiteSpace(slugActual))
                    {
                        <text>/tienda/@slugActual</text>
                    }
                </div>
            </div>

            <div class="pt-field">
                <label for="Bio">Descripción breve de la tienda</label>
                <textarea id="Bio" name="Bio" maxlength="500"
                          placeholder="Ej: Moda ecuatoriana, tallas S a XL. Envíos a todo el país.">@Model.Bio</textarea>
                <small>Máximo 500 caracteres. Visible en el perfil público.</small>
            </div>
        </div>

        <!-- ── Banner ── -->
        <div class="pt-section">
            <h2><i class="fas fa-image" style="color:#e91e8c"></i> Banner / portada</h2>

            @if (!string.IsNullOrWhiteSpace(Model.BannerPath))
            {
                <img class="banner-preview" id="bannerImg"
                     src="@Model.BannerPath" alt="Banner actual">
            }
            else
            {
                <img class="banner-preview" id="bannerImg"
                     src="/images/Tiendas/default-banner.jpg" alt="Sin banner">
            }

            <div class="pt-field">
                <label for="Banner">Subir nuevo banner</label>
                <input type="file" id="Banner" name="Banner"
                       accept=".jpg,.jpeg,.png,.webp"
                       onchange="previewBanner(this)">
                <small>JPG, PNG o WEBP · Máx. 5 MB · Recomendado: 1200 × 400 px</small>
            </div>
        </div>

        <!-- ── Verificación y opciones ── -->
        <div class="pt-section">
            <h2><i class="fas fa-shield-alt" style="color:#e91e8c"></i> Opciones</h2>

            <div class="toggle-row">
                <div style="flex:1">
                    <label for="Verificado">Vendedor verificado</label>
                    <small>Muestra la insignia "Verificado" en el perfil público</small>
                </div>
                <label class="switch">
                    <input type="checkbox" id="Verificado" name="Verificado" value="true"
                           @(Model.Verificado ? "checked" : "")>
                    <span class="slider"></span>
                </label>
            </div>
        </div>

        <!-- ── Redes sociales ── -->
        <div class="pt-section">
            <h2><i class="fas fa-hashtag" style="color:#e91e8c"></i> Redes sociales</h2>

            <div class="pt-field">
                <label for="InstagramUrl"><i class="fab fa-instagram"></i> Instagram</label>
                <input type="url" id="InstagramUrl" name="InstagramUrl"
                       value="@Model.InstagramUrl"
                       placeholder="https://instagram.com/tutienda">
            </div>

            <div class="pt-field">
                <label for="TikTokUrl"><i class="fab fa-tiktok"></i> TikTok</label>
                <input type="url" id="TikTokUrl" name="TikTokUrl"
                       value="@Model.TikTokUrl"
                       placeholder="https://tiktok.com/@@tutienda">
            </div>

            <div class="pt-field">
                <label for="FacebookUrl"><i class="fab fa-facebook-f"></i> Facebook</label>
                <input type="url" id="FacebookUrl" name="FacebookUrl"
                       value="@Model.FacebookUrl"
                       placeholder="https://facebook.com/tutienda">
            </div>
        </div>

        <!-- Guardar -->
        <div style="display:flex; justify-content:flex-end; gap:12px; align-items:center;">
            <a asp-action="Usuarios" class="btn-back">Cancelar</a>
            <button type="submit" class="btn-save">
                <i class="fas fa-floppy-disk"></i> Guardar cambios
            </button>
        </div>
    </form>
</div>

<script>
// Preview de banner antes de subir
function previewBanner(input) {
    if (!input.files || !input.files[0]) return;
    const reader = new FileReader();
    reader.onload = e => {
        const img = document.getElementById('bannerImg');
        if (img) img.src = e.target.result;
    };
    reader.readAsDataURL(input.files[0]);
}

// Preview del slug mientras se escribe
const slugInput = document.getElementById('Slug');
const slugPreview = document.getElementById('slugPreview');
if (slugInput && slugPreview) {
    slugInput.addEventListener('input', function () {
        const val = this.value.trim().toLowerCase().replace(/[^a-z0-9-]/g, '-').replace(/-+/g, '-');
        this.value = val;
        slugPreview.textContent = val ? '/tienda/' + val : '';
    });
}
</script>
