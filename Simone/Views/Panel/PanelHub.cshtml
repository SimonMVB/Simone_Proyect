@{
    ViewData["Title"] = "Panel Hub";
    var hub = ViewBag.Hub as Simone.Models.HubEnvio;
    var subPedidosEnCamino = ViewBag.SubPedidosEnCamino as List<Simone.Models.SubPedido> ?? new List<Simone.Models.SubPedido>();
    var subPedidosEnHub = ViewBag.SubPedidosEnHub as List<Simone.Models.SubPedido> ?? new List<Simone.Models.SubPedido>();
    var enviosPendientes = ViewBag.EnviosPendientes as List<Simone.Models.EnvioConsolidado> ?? new List<Simone.Models.EnvioConsolidado>();
    var stats = ViewBag.Stats;
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a href="@Url.Action("Index", "Panel")" class="btn btn-outline-secondary btn-sm mb-2">
                <i class="bi bi-arrow-left me-1"></i>Panel
            </a>
            <h1 class="h3 mb-1">
                <i class="bi bi-building me-2"></i>@hub?.Nombre
            </h1>
            <p class="text-muted mb-0">
                <i class="bi bi-geo-alt me-1"></i>@hub?.Direccion, @hub?.Ciudad, @hub?.Provincia
            </p>
        </div>
        <div>
            @if (hub != null)
            {
                <span class="badge bg-success fs-6">Hub Activo</span>
            }
        </div>
    </div>

    <!-- Mensajes -->
    @if (TempData["MensajeExito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-2"></i>@TempData["MensajeExito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["MensajeError"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["MensajeError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Estadísticas -->
    <div class="row mb-4 g-3">
        <div class="col-6 col-md-3">
            <div class="card bg-warning text-dark h-100">
                <div class="card-body text-center">
                    <i class="bi bi-truck fs-1"></i>
                    <h2 class="mb-0 mt-2">@stats?.EnCamino</h2>
                    <small>En Camino</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card bg-info text-white h-100">
                <div class="card-body text-center">
                    <i class="bi bi-box-seam fs-1"></i>
                    <h2 class="mb-0 mt-2">@stats?.EnHub</h2>
                    <small>En Hub</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card bg-primary text-white h-100">
                <div class="card-body text-center">
                    <i class="bi bi-boxes fs-1"></i>
                    <h2 class="mb-0 mt-2">@stats?.EnviosPendientes</h2>
                    <small>Envíos Pendientes</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card bg-success text-white h-100">
                <div class="card-body text-center">
                    <i class="bi bi-check2-circle fs-1"></i>
                    <h2 class="mb-0 mt-2">@stats?.EnviosListos</h2>
                    <small>Listos para Despachar</small>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Columna Izquierda: Paquetes por Recibir y Recibidos -->
        <div class="col-lg-6">
            <!-- Paquetes En Camino (Por Recibir) -->
            <div class="card mb-4">
                <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-truck me-2"></i>Paquetes En Camino
                    </h5>
                    <span class="badge bg-dark">@subPedidosEnCamino.Count</span>
                </div>
                <div class="card-body p-0">
                    @if (subPedidosEnCamino.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var sp in subPedidosEnCamino)
                            {
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div class="flex-grow-1">
                                            <div class="d-flex justify-content-between">
                                                <strong class="font-monospace">@sp.Codigo</strong>
                                                <small class="text-muted">
                                                    @if (sp.FechaEnvioHub.HasValue)
                                                    {
                                                        @sp.FechaEnvioHub.Value.ToString("dd/MM HH:mm")
                                                    }
                                                </small>
                                            </div>
                                            <small class="text-muted d-block">
                                                <i class="bi bi-shop me-1"></i>@(sp.Vendedor?.Nombre ?? "Tienda")
                                            </small>
                                            <small class="text-muted d-block">
                                                <i class="bi bi-bag me-1"></i>@sp.Items.Count productos
                                            </small>
                                        </div>
                                        <div class="ms-2">
                                            <button class="btn btn-success btn-sm"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#modalRecibir"
                                                    data-id="@sp.SubPedidoId"
                                                    data-codigo="@sp.Codigo"
                                                    data-tienda="@(sp.Vendedor?.Nombre ?? "Tienda")">
                                                <i class="bi bi-check-lg me-1"></i>Recibir
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="bi bi-inbox text-muted fs-1"></i>
                            <p class="text-muted mb-0 mt-2">No hay paquetes en camino</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Paquetes Recibidos en Hub -->
            <div class="card mb-4">
                <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-box-seam me-2"></i>Paquetes en Hub
                    </h5>
                    <span class="badge bg-light text-dark">@subPedidosEnHub.Count</span>
                </div>
                <div class="card-body p-0">
                    @if (subPedidosEnHub.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Código</th>
                                        <th>Tienda</th>
                                        <th>Envío</th>
                                        <th>Recibido</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var sp in subPedidosEnHub)
                                    {
                                        <tr>
                                            <td><code>@sp.Codigo</code></td>
                                            <td>@(sp.Vendedor?.Nombre ?? "-")</td>
                                            <td>
                                                <small class="font-monospace">@(sp.Envio?.Codigo ?? "-")</small>
                                            </td>
                                            <td>
                                                <small>@(sp.FechaRecepcionHub?.ToString("dd/MM HH:mm") ?? "-")</small>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="bi bi-box text-muted fs-1"></i>
                            <p class="text-muted mb-0 mt-2">No hay paquetes en el Hub</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Columna Derecha: Envíos para Despachar -->
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-boxes me-2"></i>Envíos para Despachar
                    </h5>
                    <span class="badge bg-light text-dark">@enviosPendientes.Count</span>
                </div>
                <div class="card-body p-0">
                    @if (enviosPendientes.Any())
                    {
                        <div class="accordion" id="accordionEnvios">
                            @foreach (var envio in enviosPendientes)
                            {
                                var todosEnHub = envio.SubPedidos.All(sp => sp.Estado == "EnHub");
                                var recibidos = envio.SubPedidos.Count(sp => sp.Estado == "EnHub");
                                var total = envio.SubPedidos.Count;
                                var progreso = total > 0 ? (recibidos * 100 / total) : 0;

                                <div class="accordion-item">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button collapsed" type="button"
                                                data-bs-toggle="collapse" data-bs-target="#envio-@envio.EnvioId">
                                            <div class="d-flex justify-content-between align-items-center w-100 me-3">
                                                <div>
                                                    <strong class="font-monospace">@envio.Codigo</strong>
                                                    @if (todosEnHub)
                                                    {
                                                        <span class="badge bg-success ms-2">Listo</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-warning text-dark ms-2">@recibidos/@total</span>
                                                    }
                                                </div>
                                                <small class="text-muted">@(envio.Cliente?.NombreCompleto ?? "Cliente")</small>
                                            </div>
                                        </button>
                                    </h2>
                                    <div id="envio-@envio.EnvioId" class="accordion-collapse collapse">
                                        <div class="accordion-body">
                                            <!-- Progreso -->
                                            <div class="progress mb-3" style="height: 8px;">
                                                <div class="progress-bar @(todosEnHub ? "bg-success" : "bg-warning")"
                                                     style="width: @progreso%"></div>
                                            </div>

                                            <!-- Info Cliente -->
                                            <div class="mb-3">
                                                <small class="text-muted">Destino:</small>
                                                <br>
                                                <strong>@envio.Provincia, @envio.Ciudad</strong>
                                                <br>
                                                <small>@envio.DireccionEntrega</small>
                                            </div>

                                            <!-- SubPedidos -->
                                            <div class="mb-3">
                                                <small class="text-muted">Paquetes:</small>
                                                <ul class="list-unstyled mb-0 mt-1">
                                                    @foreach (var sp in envio.SubPedidos)
                                                    {
                                                        var spIcon = sp.Estado == "EnHub" ? "bi-check-circle-fill text-success" : "bi-clock text-warning";
                                                        <li>
                                                            <i class="bi @spIcon me-1"></i>
                                                            <code>@sp.Codigo</code>
                                                            <small class="text-muted">(@sp.Estado)</small>
                                                        </li>
                                                    }
                                                </ul>
                                            </div>

                                            <!-- Acción Despachar -->
                                            @if (todosEnHub)
                                            {
                                                <hr />
                                                <form method="post" asp-action="DespacharEnvioConsolidado">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="envioId" value="@envio.EnvioId" />
                                                    <input type="hidden" name="hubId" value="@hub?.HubId" />

                                                    <div class="row g-2 mb-2">
                                                        <div class="col-8">
                                                            <input type="text" name="numeroGuia" class="form-control form-control-sm"
                                                                   placeholder="Número de guía *" required />
                                                        </div>
                                                        <div class="col-4">
                                                            <input type="text" name="transportista" class="form-control form-control-sm"
                                                                   placeholder="Transportista" />
                                                        </div>
                                                    </div>
                                                    <button type="submit" class="btn btn-success w-100">
                                                        <i class="bi bi-truck me-1"></i>Despachar Envío
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <div class="alert alert-warning mb-0 py-2">
                                                    <small>
                                                        <i class="bi bi-exclamation-triangle me-1"></i>
                                                        Faltan @(total - recibidos) paquete(s) por recibir
                                                    </small>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-box-seam text-muted fs-1"></i>
                            <p class="text-muted mb-0 mt-2">No hay envíos pendientes</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Recibir Paquete -->
<div class="modal fade" id="modalRecibir" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-action="RecibirSubPedidoEnHub">
                @Html.AntiForgeryToken()
                <input type="hidden" name="subPedidoId" id="recibirSubPedidoId" />
                <input type="hidden" name="hubId" value="@hub?.HubId" />

                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-box-arrow-in-down me-2"></i>Recibir Paquete
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info">
                        <strong>Código:</strong> <span id="recibirCodigo" class="font-monospace"></span>
                        <br>
                        <strong>Tienda:</strong> <span id="recibirTienda"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Notas (opcional)</label>
                        <textarea name="notasHub" class="form-control" rows="2"
                                  placeholder="Ej: Paquete en buen estado, sellado correcto..."></textarea>
                    </div>

                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="confirmarRecepcion" required />
                        <label class="form-check-label" for="confirmarRecepcion">
                            Confirmo que el paquete fue recibido y verificado
                        </label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-lg me-1"></i>Confirmar Recepción
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('modalRecibir').addEventListener('show.bs.modal', function (e) {
            const btn = e.relatedTarget;
            document.getElementById('recibirSubPedidoId').value = btn.dataset.id;
            document.getElementById('recibirCodigo').textContent = btn.dataset.codigo;
            document.getElementById('recibirTienda').textContent = btn.dataset.tienda;
            document.getElementById('confirmarRecepcion').checked = false;
        });
    </script>
}