@model List<Simone.Models.EnvioConsolidado>
@{
    ViewData["Title"] = "Envíos Consolidados";
    var hubs = ViewBag.Hubs as List<Simone.Models.HubEnvio> ?? new List<Simone.Models.HubEnvio>();
    var estados = ViewBag.Estados as string[] ?? Array.Empty<string>();
    var filtroEstado = ViewBag.FiltroEstado as string;
    var filtroHubId = ViewBag.FiltroHubId as int?;
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">
                <i class="bi bi-box-seam me-2"></i>Envíos Consolidados
            </h1>
            <p class="text-muted mb-0">Gestión de envíos agrupados por cliente</p>
        </div>
        <div>
            <span class="badge bg-primary fs-6">@Model.Count envíos</span>
        </div>
    </div>

    <!-- Mensajes -->
    @if (TempData["MensajeExito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-2"></i>@TempData["MensajeExito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["MensajeError"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["MensajeError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filtros -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Estado</label>
                    <select name="estado" class="form-select" onchange="this.form.submit()">
                        <option value="">-- Todos --</option>
                        @foreach (var e in estados)
                        {
                            <option value="@e" selected="@(filtroEstado == e)">@e</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Hub</label>
                    <select name="hubId" class="form-select" onchange="this.form.submit()">
                        <option value="">-- Todos --</option>
                        @foreach (var h in hubs)
                        {
                            <option value="@h.HubId" selected="@(filtroHubId == h.HubId)">@h.Nombre</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <a href="@Url.Action("EnviosConsolidados")" class="btn btn-outline-secondary">
                        <i class="bi bi-x-lg me-1"></i>Limpiar
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Tabla -->
    <div class="card">
        <div class="card-body p-0">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Código</th>
                                <th>Cliente</th>
                                <th>Destino</th>
                                <th>Hub</th>
                                <th class="text-center">SubPedidos</th>
                                <th class="text-end">Total Envío</th>
                                <th class="text-center">Estado</th>
                                <th>Fecha</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var e in Model)
                            {
                                var badgeClass = e.Estado switch
                                {
                                    "Pendiente" => "bg-warning text-dark",
                                    "EnProceso" => "bg-info",
                                    "EnHub" => "bg-primary",
                                    "EnCamino" => "bg-purple",
                                    "Entregado" => "bg-success",
                                    "Cancelado" => "bg-danger",
                                    _ => "bg-secondary"
                                };

                                <tr>
                                    <td>
                                        <strong class="font-monospace">@e.Codigo</strong>
                                        @if (!string.IsNullOrEmpty(e.NumeroGuia))
                                        {
                                            <br>
                                
                                            <small class="text-muted">Guía: @e.NumeroGuia</small>
                                        }
                                    </td>
                                    <td>
                                        @if (e.Cliente != null)
                                        {
                                            <span>@e.Cliente.NombreCompleto</span>
                                            <br>

                                            <small class="text-muted">@e.Cliente.Email</small>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Sin cliente</span>
                                        }
                                    </td>
                                    <td>
                                        <small>
                                            @e.Provincia, @e.Ciudad
                                            @if (!string.IsNullOrEmpty(e.DireccionEntrega))
                                            {
                                                <br>
                                    
                                                <span class="text-muted">@e.DireccionEntrega.Truncate(30)</span>
                                            }
                                        </small>
                                    </td>
                                    <td>
                                        @if (e.Hub != null)
                                        {
                                            <span class="badge bg-light text-dark">@e.Hub.Nombre</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-secondary">@e.SubPedidos.Count</span>
                                    </td>
                                    <td class="text-end">
                                        <strong>$@e.CostoEnvioFinal.ToString("N2")</strong>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @badgeClass">@e.Estado</span>
                                    </td>
                                    <td>
                                        <small>@e.FechaCreacion.ToString("dd/MM/yyyy")</small>
                                        <br><small class="text-muted">@e.FechaCreacion.ToString("HH:mm")</small>
                                    </td>
                                    <td class="text-end">
                                        <a href="@Url.Action("DetalleEnvioConsolidado", new { id = e.EnvioId })"
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye"></i> Ver
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox display-4 text-muted"></i>
                    <p class="text-muted mt-2">No hay envíos consolidados</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .bg-purple {
        background-color: #6f42c1 !important;
    }
</style>