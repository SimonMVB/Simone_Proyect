@model Simone.Models.EnvioConsolidado
@{
    ViewData["Title"] = $"Envío {Model.Codigo}";
    var estados = new[] { "Pendiente", "EnProceso", "EnHub", "EnCamino", "Entregado", "Cancelado" };
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a href="@Url.Action("EnviosConsolidados")" class="btn btn-outline-secondary btn-sm mb-2">
                <i class="bi bi-arrow-left me-1"></i>Volver
            </a>
            <h1 class="h3 mb-1">
                <i class="bi bi-box-seam me-2"></i>@Model.Codigo
            </h1>
        </div>
        <div>
            @{
                var badgeClass = Model.Estado switch
                {
                    "Pendiente" => "bg-warning text-dark",
                    "EnProceso" => "bg-info",
                    "EnHub" => "bg-primary",
                    "EnCamino" => "bg-purple",
                    "Entregado" => "bg-success",
                    "Cancelado" => "bg-danger",
                    _ => "bg-secondary"
                };
            }
            <span class="badge @badgeClass fs-5">@Model.Estado</span>
        </div>
    </div>

    <!-- Mensajes -->
    @if (TempData["MensajeExito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-2"></i>@TempData["MensajeExito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["MensajeError"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["MensajeError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <!-- Info Principal -->
        <div class="col-lg-8">
            <!-- Datos del Envío -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Información del Envío</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <table class="table table-sm table-borderless">
                                <tr>
                                    <th class="text-muted" style="width:40%">Cliente:</th>
                                    <td>
                                        @if (Model.Cliente != null)
                                        {
                                            <strong>@Model.Cliente.NombreCompleto</strong>
                                            <br>

                                            <small>@Model.Cliente.Email</small>
                                            <br>

                                            <small>@Model.Cliente.Telefono</small>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <th class="text-muted">Destino:</th>
                                    <td>
                                        @Model.Provincia, @Model.Ciudad
                                        <br><small>@Model.DireccionEntrega</small>
                                        @if (!string.IsNullOrEmpty(Model.ReferenciaEntrega))
                                        {
                                            <br>
                                        
                                            <small class="text-muted">Ref: @Model.ReferenciaEntrega</small>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <th class="text-muted">Teléfono:</th>
                                    <td>@Model.TelefonoContacto</td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <table class="table table-sm table-borderless">
                                <tr>
                                    <th class="text-muted" style="width:40%">Hub:</th>
                                    <td>@(Model.Hub?.Nombre ?? "Sin asignar")</td>
                                </tr>
                                <tr>
                                    <th class="text-muted">Peso Total:</th>
                                    <td>@Model.PesoTotalKg.ToString("N2") kg</td>
                                </tr>
                                <tr>
                                    <th class="text-muted">Costo Envío:</th>
                                    <td>
                                        <strong class="text-success fs-5">$@Model.CostoEnvioFinal.ToString("N2")</strong>
                                        @if (Model.DescuentoEnvio > 0)
                                        {
                                            <br>
                                        
                                            <small class="text-muted">
                                                <del>$@Model.CostoEnvioTotal.ToString("N2")</del>
                                                -$@Model.DescuentoEnvio.ToString("N2")
                                            </small>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <th class="text-muted">Guía:</th>
                                    <td>
                                        @if (!string.IsNullOrEmpty(Model.NumeroGuia))
                                        {
                                            <span class="font-monospace">@Model.NumeroGuia</span>
                                            @if (!string.IsNullOrEmpty(Model.Transportista))
                                            {
                                                <br>
                                        
                                                <small class="text-muted">@Model.Transportista</small>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">Sin asignar</span>
                                        }
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Notas))
                    {
                        <div class="alert alert-info mt-3 mb-0">
                            <i class="bi bi-sticky me-2"></i><strong>Notas:</strong> @Model.Notas
                        </div>
                    }
                </div>
            </div>

            <!-- SubPedidos -->
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-shop me-2"></i>SubPedidos por Tienda</h5>
                    <span class="badge bg-primary">@Model.SubPedidos.Count tiendas</span>
                </div>
                <div class="card-body p-0">
                    @if (Model.SubPedidos.Any())
                    {
                        <div class="accordion" id="accordionSubPedidos">
                            @foreach (var sp in Model.SubPedidos.OrderBy(s => s.Vendedor?.Nombre))
                            {
                                var spBadgeClass = sp.Estado switch
                                {
                                    "Pendiente" => "bg-warning text-dark",
                                    "Preparando" => "bg-info",
                                    "Listo" => "bg-primary",
                                    "EnCaminoHub" => "bg-purple",
                                    "EnHub" => "bg-success",
                                    "Entregado" => "bg-success",
                                    "Cancelado" => "bg-danger",
                                    _ => "bg-secondary"
                                };

                                <div class="accordion-item">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button collapsed" type="button"
                                                data-bs-toggle="collapse" data-bs-target="#sp-@sp.SubPedidoId">
                                            <div class="d-flex justify-content-between align-items-center w-100 me-3">
                                                <div>
                                                    <strong>@(sp.Vendedor?.Nombre ?? "Tienda")</strong>
                                                    <span class="text-muted ms-2">@sp.Codigo</span>
                                                </div>
                                                <div>
                                                    <span class="badge @spBadgeClass me-2">@sp.Estado</span>
                                                    <span class="badge bg-light text-dark">@sp.Items.Count items</span>
                                                    <span class="badge bg-light text-dark">$@sp.Total.ToString("N2")</span>
                                                </div>
                                            </div>
                                        </button>
                                    </h2>
                                    <div id="sp-@sp.SubPedidoId" class="accordion-collapse collapse">
                                        <div class="accordion-body">
                                            <table class="table table-sm">
                                                <thead>
                                                    <tr>
                                                        <th>Producto</th>
                                                        <th class="text-center">Cant.</th>
                                                        <th class="text-end">Precio</th>
                                                        <th class="text-end">Subtotal</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var item in sp.Items)
                                                    {
                                                        <tr>
                                                            <td>
                                                                @item.NombreProducto
                                                                @if (!string.IsNullOrEmpty(item.Color) || !string.IsNullOrEmpty(item.Talla))
                                                                {
                                                                    <br>
                                                    
                                                                    <small class="text-muted">@item.Color @item.Talla</small>
                                                                }
                                                            </td>
                                                            <td class="text-center">@item.Cantidad</td>
                                                            <td class="text-end">$@item.PrecioUnitario.ToString("N2")</td>
                                                            <td class="text-end">$@item.Subtotal.ToString("N2")</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                                <tfoot>
                                                    <tr>
                                                        <th colspan="3" class="text-end">Total:</th>
                                                        <th class="text-end">$@sp.Total.ToString("N2")</th>
                                                    </tr>
                                                </tfoot>
                                            </table>
                                            <div class="text-end">
                                                <a href="@Url.Action("DetalleSubPedido", new { id = sp.SubPedidoId })"
                                                   class="btn btn-sm btn-outline-primary">
                                                    <i class="bi bi-eye me-1"></i>Ver detalle completo
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <p class="text-muted mb-0">No hay subpedidos</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Panel Lateral -->
        <div class="col-lg-4">
            <!-- Fechas -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-calendar3 me-2"></i>Fechas</h5>
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between">
                            <span class="text-muted">Creación:</span>
                            <span>@Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</span>
                        </li>
                        @if (Model.FechaConsolidacion.HasValue)
                        {
                            <li class="list-group-item d-flex justify-content-between">
                                <span class="text-muted">Consolidación:</span>
                                <span>@Model.FechaConsolidacion.Value.ToString("dd/MM/yyyy HH:mm")</span>
                            </li>
                        }
                        @if (Model.FechaEnvio.HasValue)
                        {
                            <li class="list-group-item d-flex justify-content-between">
                                <span class="text-muted">Envío:</span>
                                <span>@Model.FechaEnvio.Value.ToString("dd/MM/yyyy HH:mm")</span>
                            </li>
                        }
                        @if (Model.FechaEntrega.HasValue)
                        {
                            <li class="list-group-item d-flex justify-content-between">
                                <span class="text-muted">Entrega:</span>
                                <span class="text-success">@Model.FechaEntrega.Value.ToString("dd/MM/yyyy HH:mm")</span>
                            </li>
                        }
                    </ul>
                </div>
            </div>

            <!-- Acciones -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-gear me-2"></i>Acciones</h5>
                </div>
                <div class="card-body">
                    <!-- Cambiar Estado -->
                    <form method="post" asp-action="CambiarEstadoEnvio" class="mb-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="envioId" value="@Model.EnvioId" />
                        <label class="form-label">Cambiar Estado</label>
                        <div class="input-group">
                            <select name="nuevoEstado" class="form-select">
                                @foreach (var e in estados)
                                {
                                    <option value="@e" selected="@(Model.Estado == e)">@e</option>
                                }
                            </select>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check"></i>
                            </button>
                        </div>
                        <div class="mt-2">
                            <input type="text" name="notas" class="form-control form-control-sm" placeholder="Nota (opcional)" />
                        </div>
                    </form>

                    <hr />

                    <!-- Asignar Guía -->
                    <form method="post" asp-action="AsignarGuiaEnvio">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="envioId" value="@Model.EnvioId" />
                        <label class="form-label">Número de Guía</label>
                        <input type="text" name="numeroGuia" class="form-control mb-2"
                               value="@Model.NumeroGuia" placeholder="Ej: SRV-123456789" />
                        <input type="text" name="transportista" class="form-control mb-2"
                               value="@Model.Transportista" placeholder="Transportista (opcional)" />
                        <button type="submit" class="btn btn-outline-primary w-100">
                            <i class="bi bi-truck me-1"></i>Guardar Guía
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-purple {
        background-color: #6f42c1 !important;
    }
</style>